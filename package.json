{
  "name": "the-music-repository",
  "version": "0.0.0",
  "private": true,
  "license": "LicenseRef-Proprietary",
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test -- --coverage",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:live": "TMR_E2E_MODE=live turbo run test:e2e",
    "db:generate": "pnpm --filter @TheY2T/tmr-api db:generate",
    "db:migrate": "pnpm --filter @TheY2T/tmr-api db:migrate",
    "infra:up": "docker compose -f infra/podman/compose.yaml up -d",
    "infra:down": "docker compose -f infra/podman/compose.yaml down",
    "app:up": "pkill -f 'astro.*dev' 2>/dev/null; pkill -f 'apps/api/dist/main.js' 2>/dev/null; docker compose -f infra/podman/compose.yaml --profile app up -d --build",
    "app:down": "docker compose -f infra/podman/compose.yaml --profile app down --remove-orphans; pkill -f 'astro.*dev' 2>/dev/null; pkill -f 'apps/api/dist/main.js' 2>/dev/null; true",
    "app:seed": "docker compose -f infra/podman/compose.yaml run --rm init",
    "obs:up": "docker compose -f infra/podman/observability/compose.observability.yaml up -d",
    "obs:down": "docker compose -f infra/podman/observability/compose.observability.yaml down",
    "spec:generate": "turbo run build:openapi generate",
    "licenses:generate": "node scripts/generate-third-party-licenses.mjs",
    "licenses:check": "pnpm licenses list --prod"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
