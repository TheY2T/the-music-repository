{
  "name": "the-music-repository",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @TheY2T/tmr-api db:generate",
    "db:migrate": "pnpm --filter @TheY2T/tmr-api db:migrate",
    "infra:up": "docker compose -f infra/podman/compose.yaml up -d db flagd meilisearch minio",
    "infra:down": "docker compose -f infra/podman/compose.yaml down",
    "obs:up": "docker compose -f infra/podman/observability/compose.observability.yaml up -d",
    "obs:down": "docker compose -f infra/podman/observability/compose.observability.yaml down",
    "spec:generate": "turbo run build:openapi generate"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
