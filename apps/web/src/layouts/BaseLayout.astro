---
import FeedbackLauncher from '@TheY2T/tmr-common-ui/FeedbackLauncher';
import NpsPrompt from '@TheY2T/tmr-common-ui/NpsPrompt';
import SiteFooter from '@TheY2T/tmr-common-ui/astro/SiteFooter.astro';
import SiteHeader from '@TheY2T/tmr-common-ui/SiteHeader';
import { buildAccountNav, buildLegalNav, buildPrimaryNav } from '@TheY2T/tmr-web-acl/nav';
import { business } from '@/lib/business';
import '@/styles/global.css';
import { htmlLang, localizedPath, splitLocalePath, t } from '@TheY2T/tmr-i18n';
import {
  buildSeo,
  jsonLdScript,
  organizationJsonLd,
  websiteJsonLd,
} from '@/lib/seo';

/**
 * The single HTML shell for every page. It owns `<head>`: the per-page title/description, the
 * self-referential (per-locale) canonical, Open Graph + Twitter card, robots directive, `hreflang`
 * alternates, and the site-wide Organization/WebSite JSON-LD — assembled by `@/lib/seo` from the props
 * below. Also sets `<html lang>`, the pre-paint dark-mode script, and the CJK font class. Pages render
 * their own `<main>` into the default slot; extra `<head>` tags go in the `head` slot. The locale comes
 * from `Astro.locals.locale` (resolved in middleware). See docs/features/seo.md + i18n.md.
 */
interface Props {
  title: string;
  /** Meta description + og:description. Pages should always pass one (item summary or a page string). */
  description?: string;
  /** Cover-art URL for og:image; falls back to the default share image when omitted. */
  image?: string;
  /** og:type — `article` for content detail pages, `website` (default) otherwise. */
  type?: 'website' | 'article';
  /** Mark private/duplicate surfaces so crawlers don't index them (kept crawlable, not disallowed). */
  noindex?: boolean;
  /** Per-page schema.org JSON-LD objects (breadcrumb, article, course, …) built via `@/lib/seo`. */
  jsonLd?: object[];
  /** ISO timestamps for article OG tags (content detail pages). */
  publishedTime?: string;
  modifiedTime?: string;
}
const { title, description, image, type, noindex, jsonLd, publishedTime, modifiedTime } =
  Astro.props;
const locale = Astro.locals.locale;
const i18nEnabled = Astro.locals.flags.i18nEnabled;
const infoViewEnabled = Astro.locals.flags.infoView;
const rawPath = new URL(Astro.request.url).pathname;
const { path } = splitLocalePath(rawPath);
const site = Astro.site;

const seo = buildSeo({ locale, site, path, title, description, image, type, noindex, i18nEnabled });

// Global navigation model (see src/lib/nav.ts) — shared by the header, mobile drawer, and footer.
const navCtx = { flags: Astro.locals.flags, user: Astro.locals.user, locale, path: rawPath };
const primaryNav = buildPrimaryNav(navCtx);
const accountNav = buildAccountNav(navCtx);
const legalNav = buildLegalNav(navCtx);
const siteName = t(locale, 'site.name');
const year = new Date().getFullYear();

// Site-wide structured data: the operator's identity (Organization) and the site entity (WebSite),
// serialized with `<` escaped so a value can't break out of the <script> block.
const siteLd = [organizationJsonLd(site?.href), websiteJsonLd(siteName, locale, site?.href)];

// DB-backed UI strings (ADR 0034): the middleware already loaded this catalogue into the i18n engine for
// SSR; serialize it so client islands hydrate `t()` from the same strings. Escape `<` so a message value
// can't break out of the <script> block.
const i18nCatalogueJson = JSON.stringify(Astro.locals.i18nCatalogue).replace(/</g, '\\u003c');
---

<html
  lang={htmlLang(locale)}
  data-theme="hybrid"
  class:list={[locale === 'zh-Hans' && 'lang-zh']}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    {seo.description && <meta name="description" content={seo.description} />}
    {seo.canonical && <link rel="canonical" href={seo.canonical} />}
    {seo.robots && <meta name="robots" content={seo.robots} />}

    {/* Open Graph + Twitter card for rich link previews. */}
    <meta property="og:type" content={seo.ogType} />
    <meta property="og:title" content={seo.title} />
    {seo.description && <meta property="og:description" content={seo.description} />}
    {seo.ogUrl && <meta property="og:url" content={seo.ogUrl} />}
    <meta property="og:site_name" content={seo.ogSiteName} />
    <meta property="og:locale" content={seo.ogLocale} />
    {seo.ogLocaleAlternates.map((l) => <meta property="og:locale:alternate" content={l} />)}
    {
      seo.ogImage && (
        <>
          <meta property="og:image" content={seo.ogImage} />
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
        </>
      )
    }
    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {type === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    <meta name="twitter:card" content={seo.twitterCard} />

    {/* Reciprocal per-locale alternates (gated on the i18n flag). */}
    {seo.alternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}

    <script is:inline>
      // Apply the aesthetic + mode before paint to avoid a flash. Two independent hooks on <html>:
      // aesthetic → `data-theme` (default `hybrid`, from `tmr.aesthetic`); mode → `.dark` class
      // (from `theme`, falling back to the OS preference). See design-tokens/tokens.css (ADR 0021).
      const doc = document.documentElement;
      const aesthetic = localStorage.getItem('tmr.aesthetic');
      if (aesthetic === 'hybrid' || aesthetic === 'heritage' || aesthetic === 'warm-minimal') {
        doc.setAttribute('data-theme', aesthetic);
      }
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        doc.classList.add('dark');
      }
    </script>
    <script id="i18n-catalogue" type="application/json" is:inline set:html={i18nCatalogueJson} />
    <script>
      // Hydrate the i18n engine's registry from the embedded catalogue before any island renders, so
      // client-side `t(locale, key)` resolves from the same DB strings the server rendered (ADR 0034).
      import { hydrateCatalogueFromDom } from '@TheY2T/tmr-i18n';
      hydrateCatalogueFromDom();
    </script>

    {/* Site-wide + per-page structured data. */}
    {siteLd.map((ld) => (
      <script type="application/ld+json" is:inline set:html={jsonLdScript(ld)} />
    ))}
    {jsonLd?.map((ld) => (
      <script type="application/ld+json" is:inline set:html={jsonLdScript(ld)} />
    ))}
    <slot name="head" />
  </head>
  <body class="flex min-h-svh flex-col">
    <SiteHeader
      client:load
      locale={locale}
      siteName={siteName}
      primaryNav={primaryNav}
      accountNav={accountNav}
      user={Astro.locals.user}
      i18nEnabled={i18nEnabled}
      infoView={infoViewEnabled}
      catalogueHref={localizedPath(locale, '/catalogue')}
      homeHref={localizedPath(locale, '/')}
    />
    <div class="flex-1">
      <slot />
    </div>
    <SiteFooter
      locale={locale}
      siteName={siteName}
      primaryNav={primaryNav}
      accountNav={accountNav}
      legalNav={legalNav}
      tradingName={business.tradingName}
      abn={business.abn}
      year={year}
    />
    {
      Astro.locals.flags.feedbackLauncher && (
        <FeedbackLauncher
          client:idle
          locale={locale}
          bugsEnabled={Astro.locals.flags.feedbackBugs}
          signedIn={Boolean(Astro.locals.user)}
        />
      )
    }
    {
      Astro.locals.flags.feedbackNps && Astro.locals.user && (
        <NpsPrompt client:idle locale={locale} signedIn source={path} />
      )
    }
  </body>
</html>
