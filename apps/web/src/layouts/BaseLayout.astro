---
import SiteFooter from '@TheY2T/tmr-common-ui/astro/SiteFooter.astro';
import SiteHeader from '@TheY2T/tmr-common-ui/SiteHeader';
import { buildAccountNav, buildLegalNav, buildPrimaryNav } from '@TheY2T/tmr-web-acl/nav';
import { business } from '@/lib/business';
import '@/styles/global.css';
import { LOCALES, htmlLang, localizedPath, splitLocalePath, t } from '@TheY2T/tmr-i18n';

/**
 * The single HTML shell for every page: dynamic `<html lang>`, the pre-paint dark-mode script,
 * `hreflang` alternates, the CJK font class, and a top bar hosting the global language switcher.
 * Pages render their own `<main>` into the default slot; extra `<head>` tags go in the `head` slot.
 * The locale comes from `Astro.locals.locale` (resolved in middleware). See docs/features/i18n.md.
 */
interface Props {
  title: string;
}
const { title } = Astro.props;
const locale = Astro.locals.locale;
const i18nEnabled = Astro.locals.flags.i18nEnabled;
const rawPath = new URL(Astro.request.url).pathname;
const { path } = splitLocalePath(rawPath);
const site = Astro.site;
const alternateHref = (target: (typeof LOCALES)[number]) =>
  site ? new URL(localizedPath(target, path), site).href : localizedPath(target, path);

// Global navigation model (see src/lib/nav.ts) — shared by the header, mobile drawer, and footer.
const navCtx = { flags: Astro.locals.flags, user: Astro.locals.user, locale, path: rawPath };
const primaryNav = buildPrimaryNav(navCtx);
const accountNav = buildAccountNav(navCtx);
const legalNav = buildLegalNav(navCtx);
const siteName = t(locale, 'site.name');
const year = new Date().getFullYear();

// schema.org Organization structured data — publishes the operator's identity (trading name + ABN)
// and contact point for search engines and business verification. Escape `<` so a value can't break
// out of the <script> block.
const orgJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  legalName: business.tradingName,
  ...(site ? { url: site.href } : {}),
  identifier: {
    '@type': 'PropertyValue',
    propertyID: 'ABN',
    value: business.abnRaw,
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    email: business.contactEmail,
  },
}).replace(/</g, '\\u003c');

// DB-backed UI strings (ADR 0034): the middleware already loaded this catalogue into the i18n engine for
// SSR; serialize it so client islands hydrate `t()` from the same strings. Escape `<` so a message value
// can't break out of the <script> block.
const i18nCatalogueJson = JSON.stringify(Astro.locals.i18nCatalogue).replace(/</g, '\\u003c');
---

<html
  lang={htmlLang(locale)}
  data-theme="hybrid"
  class:list={[locale === 'zh-Hans' && 'lang-zh']}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script is:inline>
      // Apply the aesthetic + mode before paint to avoid a flash. Two independent hooks on <html>:
      // aesthetic → `data-theme` (default `hybrid`, from `tmr.aesthetic`); mode → `.dark` class
      // (from `theme`, falling back to the OS preference). See design-tokens/tokens.css (ADR 0021).
      const doc = document.documentElement;
      const aesthetic = localStorage.getItem('tmr.aesthetic');
      if (aesthetic === 'hybrid' || aesthetic === 'heritage' || aesthetic === 'warm-minimal') {
        doc.setAttribute('data-theme', aesthetic);
      }
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        doc.classList.add('dark');
      }
    </script>
    <script id="i18n-catalogue" type="application/json" is:inline set:html={i18nCatalogueJson} />
    <script>
      // Hydrate the i18n engine's registry from the embedded catalogue before any island renders, so
      // client-side `t(locale, key)` resolves from the same DB strings the server rendered (ADR 0034).
      import { hydrateCatalogueFromDom } from '@TheY2T/tmr-i18n';
      hydrateCatalogueFromDom();
    </script>
    {
      i18nEnabled && (
        <>
          {LOCALES.map((l) => (
            <link rel="alternate" hreflang={htmlLang(l)} href={alternateHref(l)} />
          ))}
          <link rel="alternate" hreflang="x-default" href={alternateHref('en')} />
        </>
      )
    }
    <script type="application/ld+json" is:inline set:html={orgJsonLd} />
    <slot name="head" />
  </head>
  <body class="flex min-h-svh flex-col">
    <SiteHeader
      client:load
      locale={locale}
      siteName={siteName}
      primaryNav={primaryNav}
      accountNav={accountNav}
      user={Astro.locals.user}
      i18nEnabled={i18nEnabled}
      catalogueHref={localizedPath(locale, '/catalogue')}
      homeHref={localizedPath(locale, '/')}
    />
    <div class="flex-1">
      <slot />
    </div>
    <SiteFooter
      locale={locale}
      siteName={siteName}
      primaryNav={primaryNav}
      accountNav={accountNav}
      legalNav={legalNav}
      tradingName={business.tradingName}
      abn={business.abn}
      year={year}
    />
  </body>
</html>
