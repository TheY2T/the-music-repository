---
import MockCheckout from '@/components/MockCheckout.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@TheY2T/tmr-i18n';

// Dev-only mock checkout page (the mock gateway redirects here). Requires the flag + an authed user.
if (!Astro.locals.flags.premium) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/upgrade');
}
const locale = Astro.locals.locale;
---

<BaseLayout title={t(locale, 'checkout.pageTitle')}>
  <main class="mx-auto max-w-lg space-y-6 p-8">
    <header class="space-y-1">
      <h1 class="text-2xl font-bold">{t(locale, 'checkout.title')}</h1>
      <p class="text-muted-foreground">{t(locale, 'checkout.subtitle')}</p>
    </header>
    <MockCheckout client:load locale={locale} />
  </main>
</BaseLayout>
