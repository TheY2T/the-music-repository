---
import MockCheckout from '@TheY2T/tmr-common-ui/MockCheckout';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

// Dev-only mock checkout page (the mock gateway redirects here). Requires the flag + an authed user.
if (!Astro.locals.flags.premium) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/upgrade');
}
const locale = Astro.locals.locale;
---

<BaseLayout noindex title={t(locale, 'checkout.pageTitle')}>
  <PageShell
    title={t(locale, 'checkout.title')}
    subtitle={t(locale, 'checkout.subtitle')}
    maxWidth="max-w-lg"
  >
    <MockCheckout client:load locale={locale} />
  </PageShell>
</BaseLayout>
