---
import ClassroomsManager from '@/components/ClassroomsManager.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

// Teacher mode: requires the flag on and an authenticated user.
if (!Astro.locals.flags.classrooms) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/classrooms');
}
// Only teachers/admins may create classrooms (RBAC: classroom:create).
const canCreate = ['admin', 'teacher'].includes(Astro.locals.user.role ?? '');
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'nav.classrooms')} — ${t(locale, 'site.name')}`}>
  <PageShell
    title={t(locale, 'nav.classrooms')}
    subtitle={t(locale, 'classrooms.subtitle')}
    back={{ href: localizedPath(locale, '/'), label: t(locale, 'common.backHome') }}
    maxWidth="max-w-3xl"
  >
    <ClassroomsManager client:load canCreate={canCreate} locale={locale} />
  </PageShell>
</BaseLayout>
