---
import UpgradePanel from '@/components/UpgradePanel.tsx';
import '@/styles/global.css';

// Monetization: requires the flag on and an authenticated user.
if (!Astro.locals.flags.premium) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/upgrade');
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Upgrade — The Music Repository</title>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <main class="mx-auto max-w-2xl space-y-6 p-8">
      <header class="space-y-1">
        <a href="/catalogue" class="text-sm text-muted-foreground underline">← Catalogue</a>
        <h1 class="text-3xl font-bold">Premium</h1>
        <p class="text-muted-foreground">Unlock premium scores, recordings, and lessons.</p>
      </header>
      <UpgradePanel client:load />
    </main>
  </body>
</html>
