---
import UpgradePanel from '@TheY2T/tmr-common-ui/UpgradePanel';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

// Monetization: requires the flag on and an authenticated user.
if (!Astro.locals.flags.premium) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/upgrade');
}
const locale = Astro.locals.locale;
---

<BaseLayout title={t(locale, 'upgrade.pageTitle')}>
  <PageShell
    title={t(locale, 'upgrade.title')}
    subtitle={t(locale, 'upgrade.subtitle')}
    back={{ href: localizedPath(locale, '/catalogue'), label: t(locale, 'common.backCatalogue') }}
    maxWidth="max-w-2xl"
  >
    <UpgradePanel client:load locale={locale} />
  </PageShell>
</BaseLayout>
