---
import UpgradePanel from '@/components/UpgradePanel.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';

// Monetization: requires the flag on and an authenticated user.
if (!Astro.locals.flags.premium) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/upgrade');
}
const locale = Astro.locals.locale;
---

<BaseLayout title={t(locale, 'upgrade.pageTitle')}>
  <main class="mx-auto max-w-2xl space-y-6 p-8">
    <header class="space-y-1">
      <a href={localizedPath(locale, '/catalogue')} class="text-sm text-muted-foreground underline">
        {t(locale, 'common.backCatalogue')}
      </a>
      <h1 class="text-3xl font-bold">{t(locale, 'upgrade.title')}</h1>
      <p class="text-muted-foreground">{t(locale, 'upgrade.subtitle')}</p>
    </header>
    <UpgradePanel client:load locale={locale} />
  </main>
</BaseLayout>
