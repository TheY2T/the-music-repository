---
import AcceptInvitation from '@/components/AcceptInvitation.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@TheY2T/tmr-i18n';

if (!Astro.locals.flags.classrooms) {
  return Astro.redirect('/');
}
// Preserve the token through sign-in so the accept completes afterwards.
if (!Astro.locals.user) {
  const token = Astro.url.searchParams.get('token') ?? '';
  return Astro.redirect(`/signin?redirect=${encodeURIComponent(`/classrooms/accept?token=${token}`)}`);
}
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'classrooms.acceptHeading')} — ${t(locale, 'site.name')}`}>
  <main class="mx-auto max-w-lg space-y-6 p-8">
    <header class="space-y-1">
      <h1 class="text-2xl font-bold">{t(locale, 'classrooms.acceptHeading')}</h1>
    </header>
    <AcceptInvitation client:load locale={locale} />
  </main>
</BaseLayout>
