---
import AdminFlagManager from '@TheY2T/tmr-common-ui/AdminFlagManager';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { guardAdmin } from '@/lib/admin-guard';

const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
if (!Astro.locals.flags.featureFlags) {
  return Astro.redirect('/admin');
}
const locale = Astro.locals.locale;
// The environment this deployment resolves flags against (matches middleware's snapshot fetch), so the
// admin editor defaults to + marks the env the live site actually reads.
const appEnv = process.env.APP_ENV ?? 'dev';
---

<BaseLayout noindex title={`${t(locale, 'flagadmin.title')} — ${t(locale, 'nav.admin')}`}>
  <PageShell
    title={t(locale, 'flagadmin.title')}
    subtitle={t(locale, 'flagadmin.subtitle')}
    back={{ href: localizedPath(locale, '/admin'), label: t(locale, 'common.backContent') }}
    maxWidth="max-w-6xl"
  >
    <AdminFlagManager client:load locale={locale} appEnv={appEnv} />
  </PageShell>
</BaseLayout>
