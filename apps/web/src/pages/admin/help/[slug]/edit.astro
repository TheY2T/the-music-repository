---
import HelpTopicForm from '@TheY2T/tmr-common-ui/HelpTopicForm';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { guardAdmin } from '@/lib/admin-guard';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
if (!Astro.locals.flags.infoView) {
  return Astro.redirect('/admin');
}
const { slug } = Astro.params;
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'admin.editHelp')} — ${t(locale, 'nav.admin')}`}>
  <PageShell
    title={t(locale, 'admin.editHelp')}
    back={{ href: localizedPath(locale, '/admin/help'), label: t(locale, 'common.backHelpTopics') }}
    maxWidth="max-w-5xl"
  >
    <HelpTopicForm
      client:load
      slug={slug}
      locale={locale}
      blockEditor={Astro.locals.flags.blockEditor}
      preview={Astro.locals.flags.blockEditorPreview}
      localeStrings={Astro.locals.flags.localeStrings}
    />
  </PageShell>
</BaseLayout>
