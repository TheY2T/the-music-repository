---
import AdminHelpManager from '@/components/AdminHelpManager.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { guardAdmin } from '@/lib/admin-guard';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
if (!Astro.locals.flags.infoView) {
  return Astro.redirect('/admin');
}
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'admin.helpTopics')} — ${t(locale, 'nav.admin')}`}>
  <PageShell
    title={t(locale, 'admin.helpTopics')}
    subtitle={t(locale, 'admin.helpSubtitle')}
    back={{ href: localizedPath(locale, '/admin'), label: t(locale, 'common.backContent') }}
  >
    <AdminHelpManager client:load locale={locale} />
  </PageShell>
</BaseLayout>
