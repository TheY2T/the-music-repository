---
import AdminContentList from '@/components/AdminContentList.tsx';
import SignOutButton from '@/components/SignOutButton.tsx';
import { guardAdmin } from '@/lib/admin-guard';
import '@/styles/global.css';

const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
const user = Astro.locals.user!;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin — The Music Repository</title>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <main class="mx-auto max-w-5xl space-y-6 p-8">
      <header class="flex items-center justify-between">
        <div class="space-y-1">
          <a href="/" class="text-sm text-muted-foreground underline">← Home</a>
          <h1 class="text-3xl font-bold">Content</h1>
          <p class="text-sm text-muted-foreground">
            Signed in as {user.name || user.email} · role: {user.role}
          </p>
        </div>
        <SignOutButton client:load />
      </header>

      <AdminContentList client:load />
    </main>
  </body>
</html>
