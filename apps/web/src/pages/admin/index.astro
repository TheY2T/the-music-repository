---
import AdminContentList from '@/components/AdminContentList.tsx';
import SignOutButton from '@/components/SignOutButton.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { guardAdmin } from '@/lib/admin-guard';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import Icon from '@TheY2T/tmr-ui/astro/Icon.astro';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
const user = Astro.locals.user!;
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'nav.admin')} — ${t(locale, 'site.name')}`}>
  <PageShell
    title={t(locale, 'admin.content')}
    subtitle={t(locale, 'admin.signedInAs', { who: user.name || user.email, role: user.role ?? '' })}
    back={{ href: localizedPath(locale, '/'), label: t(locale, 'common.backHome') }}
    maxWidth="max-w-5xl"
  >
    <Fragment slot="actions">
      <SignOutButton client:load locale={locale} />
    </Fragment>

    <div class="flex flex-wrap gap-4">
      {
        Astro.locals.flags.collections && (
          <a
            href={localizedPath(locale, '/admin/collections')}
            class="inline-flex items-center gap-1 text-sm underline"
          >
            {t(locale, 'admin.manageCollections')}
            <Icon name="arrow-right" class="size-4" />
          </a>
        )
      }
      {
        Astro.locals.flags.infoView && (
          <a
            href={localizedPath(locale, '/admin/help')}
            class="inline-flex items-center gap-1 text-sm underline"
          >
            {t(locale, 'admin.manageHelp')}
            <Icon name="arrow-right" class="size-4" />
          </a>
        )
      }
    </div>

    <AdminContentList client:load locale={locale} />
  </PageShell>
</BaseLayout>
