---
import AdminContentManager from '@TheY2T/tmr-common-ui/AdminContentManager';
import AdminNav from '@TheY2T/tmr-common-ui/AdminNav';
import SignOutButton from '@TheY2T/tmr-common-ui/SignOutButton';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { guardAdmin } from '@/lib/admin-guard';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
const user = Astro.locals.user!;
const locale = Astro.locals.locale;
---

<BaseLayout noindex title={`${t(locale, 'nav.admin')} — ${t(locale, 'site.name')}`}>
  <PageShell
    title={t(locale, 'nav.admin')}
    subtitle={t(locale, 'admin.signedInAs', { who: user.name || user.email, role: user.role ?? '' })}
    back={{ href: localizedPath(locale, '/'), label: t(locale, 'common.backHome') }}
    maxWidth="max-w-5xl"
  >
    <Fragment slot="actions">
      <SignOutButton client:load locale={locale} />
    </Fragment>

    <div class="space-y-8">
      <AdminNav
        locale={locale}
        showCollections={Astro.locals.flags.collections}
        showHelp={Astro.locals.flags.infoView}
        showFaq={Astro.locals.flags.faq}
        showLocaleStrings={Astro.locals.flags.localeStrings}
        showFeatureFlags={Astro.locals.flags.featureFlags}
      />

      <section id="admin-content" class="space-y-4">
        <AdminContentManager client:load locale={locale} />
      </section>
    </div>
  </PageShell>
</BaseLayout>
