---
import HelpPreview from '@TheY2T/tmr-common-ui/admin/block-editor/HelpPreview';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { guardAdmin } from '@/lib/admin-guard';
import { t } from '@TheY2T/tmr-i18n';

// Draft preview surface for the help-topic editor (Phase C). Gated by guardAdmin; renders no DB data —
// the editor pushes the live topic in via postMessage. `[slug]` only keys the iframe.
const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'blockEditor.previewTitle')} — ${t(locale, 'site.name')}`}>
  <HelpPreview client:only="react" locale={locale} />
</BaseLayout>
