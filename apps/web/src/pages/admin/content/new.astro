---
import ContentForm from '@/components/ContentForm.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { guardAdmin } from '@/lib/admin-guard';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'admin.newContent')} — ${t(locale, 'site.name')}`}>
  <PageShell
    title={t(locale, 'admin.newContent')}
    back={{ href: localizedPath(locale, '/admin'), label: t(locale, 'common.backContent') }}
    maxWidth="max-w-5xl"
  >
    <ContentForm
      client:load
      locale={locale}
      blockEditor={Astro.locals.flags.blockEditor}
      preview={Astro.locals.flags.blockEditorPreview}
      interactive={Astro.locals.flags.interactiveScores}
    />
  </PageShell>
</BaseLayout>
