---
import ContentForm from '@/components/ContentForm.tsx';
import { guardAdmin } from '@/lib/admin-guard';
import '@/styles/global.css';

const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>New content — The Music Repository</title>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <main class="mx-auto max-w-5xl space-y-6 p-8">
      <header class="space-y-1">
        <a href="/admin" class="text-sm text-muted-foreground underline">← Content</a>
        <h1 class="text-3xl font-bold">New content</h1>
      </header>
      <ContentForm client:load />
    </main>
  </body>
</html>
