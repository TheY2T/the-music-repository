---
import ContentForm from '@/components/ContentForm.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { guardAdmin } from '@/lib/admin-guard';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
const { slug } = Astro.params;
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'admin.editContent')} — ${t(locale, 'site.name')}`}>
  <PageShell
    title={t(locale, 'admin.editContent')}
    back={{ href: localizedPath(locale, '/admin'), label: t(locale, 'common.backContent') }}
    maxWidth="max-w-5xl"
  >
    <ContentForm client:load slug={slug} locale={locale} />
  </PageShell>
</BaseLayout>
