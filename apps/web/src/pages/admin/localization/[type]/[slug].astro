---
import ContentLocalizationEditor from '@TheY2T/tmr-common-ui/ContentLocalizationEditor';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { guardAdmin } from '@/lib/admin-guard';
import { localizedPath, type MessageKey, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
if (!Astro.locals.flags.localeStrings) {
  return Astro.redirect('/admin');
}
const locale = Astro.locals.locale;
const { type, slug } = Astro.params;

const TYPES = {
  catalogue: { entityType: 'content', sectionKey: 'loc.catalogue' },
  collections: { entityType: 'collection', sectionKey: 'loc.collections' },
  help: { entityType: 'help', sectionKey: 'loc.help' },
} as const;
const config = type ? TYPES[type as keyof typeof TYPES] : undefined;
if (!config || !slug) {
  return Astro.redirect('/admin/localization');
}
const section = t(locale, config.sectionKey as MessageKey);
---

<BaseLayout title={`${t(locale, 'loc.listTitle', { section })} — ${t(locale, 'nav.admin')}`}>
  <PageShell
    title={t(locale, 'loc.listTitle', { section })}
    back={{
      href: localizedPath(locale, `/admin/localization/${type}`),
      label: t(locale, 'loc.backToSection', { section }),
    }}
    maxWidth="max-w-5xl"
  >
    <ContentLocalizationEditor
      client:load
      locale={locale}
      entityType={config.entityType}
      slug={slug}
      blockEditor={Astro.locals.flags.blockEditor}
      interactive={Astro.locals.flags.interactiveScores}
    />
  </PageShell>
</BaseLayout>
