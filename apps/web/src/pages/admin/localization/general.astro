---
import AdminLocaleManager from '@TheY2T/tmr-common-ui/AdminLocaleManager';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { guardAdmin } from '@/lib/admin-guard';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
if (!Astro.locals.flags.localeStrings) {
  return Astro.redirect('/admin');
}
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'loc.general')} — ${t(locale, 'nav.admin')}`}>
  <PageShell
    title={t(locale, 'loc.general')}
    subtitle={t(locale, 'loc.generalDesc')}
    back={{ href: localizedPath(locale, '/admin/localization'), label: t(locale, 'loc.backHub') }}
    maxWidth="max-w-6xl"
  >
    <AdminLocaleManager client:load locale={locale} />
  </PageShell>
</BaseLayout>
