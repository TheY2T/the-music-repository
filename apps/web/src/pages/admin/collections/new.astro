---
import CollectionForm from '@/components/CollectionForm.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { guardAdmin } from '@/lib/admin-guard';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
if (!Astro.locals.flags.collections) {
  return Astro.redirect('/admin');
}
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'admin.newCollection')} — ${t(locale, 'nav.admin')}`}>
  <PageShell
    title={t(locale, 'admin.newCollection')}
    back={{ href: localizedPath(locale, '/admin/collections'), label: t(locale, 'common.backCollections') }}
    maxWidth="max-w-5xl"
  >
    <CollectionForm client:load locale={locale} blockEditor={Astro.locals.flags.blockEditor}
      preview={Astro.locals.flags.blockEditorPreview}
    />
  </PageShell>
</BaseLayout>
