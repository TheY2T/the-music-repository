---
import CollectionForm from '@TheY2T/tmr-common-ui/CollectionForm';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { guardAdmin } from '@/lib/admin-guard';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
if (!Astro.locals.flags.collections) {
  return Astro.redirect('/admin');
}
const { slug } = Astro.params;
const locale = Astro.locals.locale;
---

<BaseLayout noindex title={`${t(locale, 'admin.editCollection')} — ${t(locale, 'nav.admin')}`}>
  <PageShell
    title={t(locale, 'admin.editCollection')}
    back={{ href: localizedPath(locale, '/admin/collections'), label: t(locale, 'common.backCollections') }}
    maxWidth="max-w-5xl"
  >
    <CollectionForm
      client:load
      slug={slug}
      locale={locale}
      blockEditor={Astro.locals.flags.blockEditor}
      preview={Astro.locals.flags.blockEditorPreview}
      localeStrings={Astro.locals.flags.localeStrings}
    />
  </PageShell>
</BaseLayout>
