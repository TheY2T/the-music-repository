---
import AdminCollectionList from '@/components/AdminCollectionList.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { guardAdmin } from '@/lib/admin-guard';
import { localizedPath, t } from '@TheY2T/tmr-i18n';

const redirect = guardAdmin(Astro);
if (redirect) {
  return redirect;
}
if (!Astro.locals.flags.collections) {
  return Astro.redirect('/admin');
}
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'admin.collections')} — ${t(locale, 'nav.admin')}`}>
  <main class="mx-auto max-w-5xl space-y-6 p-8">
    <header class="space-y-1">
      <a href={localizedPath(locale, '/admin')} class="text-sm text-muted-foreground underline">
        {t(locale, 'common.backContent')}
      </a>
      <h1 class="text-3xl font-bold">{t(locale, 'admin.collections')}</h1>
    </header>
    <AdminCollectionList client:load locale={locale} />
  </main>
</BaseLayout>
