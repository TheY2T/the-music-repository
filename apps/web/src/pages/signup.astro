---
import SignUpForm from '@TheY2T/tmr-common-ui/SignUpForm';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import { buttonVariants, cn } from '@TheY2T/tmr-ui';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

// Self-service sign-up is gated; fall back to sign-in when it's off.
if (!Astro.locals.flags.authSignup) {
  return Astro.redirect('/signin');
}
// Already authenticated? Nothing to sign up for.
if (Astro.locals.user) {
  return Astro.redirect('/');
}
const locale = Astro.locals.locale;
const showSocial = Astro.locals.flags.authSocial;
const showFacebook = Astro.locals.flags.authFacebook;
const showMicrosoft = Astro.locals.flags.authMicrosoft;
const showMicrosoftWork = Astro.locals.flags.authMicrosoftWork;
const showWhatsapp = Astro.locals.flags.authWhatsapp;
const showApple = Astro.locals.flags.authApple;
---

<BaseLayout noindex title={t(locale, 'signup.title')}>
  <PageShell maxWidth="max-w-md" class="flex min-h-screen flex-col justify-center">
    <header class="mb-6 space-y-1 text-center">
      <a
        href={localizedPath(locale, '/')}
        class={cn(buttonVariants({ variant: 'link', size: 'sm' }), 'text-muted-foreground')}
      >
        {t(locale, 'common.backHome')}
      </a>
      <h1 class="font-display text-3xl font-semibold tracking-tight">
        {t(locale, 'signup.heading')}
      </h1>
      <p class="text-muted-foreground">{t(locale, 'signup.subtitle')}</p>
    </header>
    <SignUpForm
      client:load
      locale={locale}
      showSocial={showSocial}
      showFacebook={showFacebook}
      showMicrosoft={showMicrosoft}
      showMicrosoftWork={showMicrosoftWork}
      showWhatsapp={showWhatsapp}
      showApple={showApple}
    />
  </PageShell>
</BaseLayout>
