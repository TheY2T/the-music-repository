---
import MyFavorites from '@/components/MyFavorites.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

// Personalization: requires the flag on and an authenticated user.
if (!Astro.locals.flags.favorites) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/me/favorites');
}
const locale = Astro.locals.locale;
const showMonetization = Astro.locals.flags.monetizationMessaging;
---

<BaseLayout title={`${t(locale, 'nav.myFavorites')} — ${t(locale, 'site.name')}`}>
  <PageShell
    title={t(locale, 'nav.myFavorites')}
    back={{ href: localizedPath(locale, '/catalogue'), label: t(locale, 'common.backCatalogue') }}
    maxWidth="max-w-6xl"
  >
    <MyFavorites client:load locale={locale} showMonetization={showMonetization} />
  </PageShell>
</BaseLayout>
