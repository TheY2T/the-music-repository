---
import MyFavorites from '@/components/MyFavorites.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';

// Personalization: requires the flag on and an authenticated user.
if (!Astro.locals.flags.favorites) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/me/favorites');
}
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'nav.myFavorites')} — ${t(locale, 'site.name')}`}>
  <main class="mx-auto max-w-6xl space-y-6 p-8">
    <header class="space-y-1">
      <a href={localizedPath(locale, '/catalogue')} class="text-sm text-muted-foreground underline">
        {t(locale, 'common.backCatalogue')}
      </a>
      <h1 class="text-3xl font-bold">{t(locale, 'nav.myFavorites')}</h1>
    </header>
    <MyFavorites client:load locale={locale} />
  </main>
</BaseLayout>
