---
import UserCollectionForm from '@TheY2T/tmr-common-ui/UserCollectionForm';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

const { flags, user, locale } = Astro.locals;
if (!flags.userCollections) {
  return Astro.redirect('/');
}
if (!user) {
  return Astro.redirect('/signin?redirect=/me/collections');
}
const { slug = '' } = Astro.params;
---

<BaseLayout title={t(locale, 'ucoll.pageTitleEdit')}>
  <PageShell
    title={t(locale, 'ucoll.titleEdit')}
    back={{ href: localizedPath(locale, '/me/collections'), label: t(locale, 'collections.savedTitle') }}
    maxWidth="max-w-2xl"
  >
    <UserCollectionForm client:load slug={slug} locale={locale} />
  </PageShell>
</BaseLayout>
