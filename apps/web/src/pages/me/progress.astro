---
import ProgressDashboard from '@TheY2T/tmr-common-ui/ProgressDashboard';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

if (!Astro.locals.flags.progress) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/me/progress');
}
const locale = Astro.locals.locale;
const includeSaved = Astro.locals.flags.collectionBookmarks;
---

<BaseLayout noindex title={`${t(locale, 'nav.myProgress')} — ${t(locale, 'site.name')}`}>
  <PageShell
    title={t(locale, 'nav.myProgress')}
    back={{ href: localizedPath(locale, '/'), label: t(locale, 'common.backHome') }}
    maxWidth="max-w-3xl"
  >
    <ProgressDashboard client:load locale={locale} includeSaved={includeSaved} />
  </PageShell>
</BaseLayout>
