---
import ProgressDashboard from '@/components/ProgressDashboard.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';

if (!Astro.locals.flags.progress) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/me/progress');
}
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'nav.myProgress')} — ${t(locale, 'site.name')}`}>
  <main class="mx-auto max-w-3xl space-y-6 p-8">
    <header class="space-y-1">
      <a href={localizedPath(locale, '/')} class="text-sm text-muted-foreground underline">
        {t(locale, 'common.backHome')}
      </a>
      <h1 class="text-3xl font-bold">{t(locale, 'nav.myProgress')}</h1>
    </header>
    <ProgressDashboard client:load locale={locale} />
  </main>
</BaseLayout>
