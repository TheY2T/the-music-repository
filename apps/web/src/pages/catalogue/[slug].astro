---
import CompleteButton from '@/components/CompleteButton.tsx';
import ContentDetail from '@/components/ContentDetail.tsx';
import FavoriteButton from '@/components/FavoriteButton.tsx';
import '@/styles/global.css';

const { slug = '' } = Astro.params;
const loggedIn = !!Astro.locals.user;
const showFavorite = Astro.locals.flags.favorites && loggedIn;
const showComplete = Astro.locals.flags.progress && loggedIn;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The Music Repository</title>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <main class="mx-auto max-w-3xl space-y-6 p-8">
      <div class="flex items-center justify-between">
        <a href="/catalogue" class="text-sm text-muted-foreground underline">← Catalogue</a>
        <div class="flex items-center gap-3">
          {showComplete && <CompleteButton client:load slug={slug} />}
          {showFavorite && <FavoriteButton client:load slug={slug} />}
        </div>
      </div>
      <ContentDetail client:load slug={slug} />
    </main>
  </body>
</html>
