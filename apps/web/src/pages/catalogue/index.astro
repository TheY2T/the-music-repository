---
import CatalogueBrowser from '@/components/islands/CatalogueBrowser';
import CatalogueHub from '@/components/islands/CatalogueHub';
import InfoView from '@TheY2T/tmr-common-ui/InfoView';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { enabledFlagshipToolSlugs } from '@TheY2T/tmr-musickit-ui/data/tools-taxonomy';
import { localizedPath, type MessageKey, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

const showFavorites = Astro.locals.flags.favorites && !!Astro.locals.user;
const locale = Astro.locals.locale;
const hub = Astro.locals.flags.catalogueHub;
const showCollections = Astro.locals.flags.collections;
const showInfoView = Astro.locals.flags.infoView;
// Premium badges are monetization messaging — hidden while monetization is deferred.
const showMonetization = Astro.locals.flags.monetizationMessaging;

// Resolve the flagship tools enabled for this viewer (each gated by its own `tools.*` flag).
const flags = Astro.locals.flags as unknown as Record<string, boolean>;
const tools = enabledFlagshipToolSlugs(flags).map((slug) => ({
  slug,
  title: t(locale, `tool.${slug}.title` as MessageKey),
  summary: t(locale, `tool.${slug}.summary` as MessageKey),
}));
---

<BaseLayout title={t(locale, 'catalogue.pageTitle')} description={t(locale, 'seo.catalogue.description')}>
  <PageShell
    title={t(locale, 'catalogue.title')}
    subtitle={t(locale, 'catalogue.subtitle')}
    back={{ href: localizedPath(locale, '/'), label: t(locale, 'common.backHome') }}
    maxWidth="max-w-6xl"
  >
    {
      hub ? (
        <CatalogueHub
          client:load
          showFavorites={showFavorites}
          showCollections={showCollections}
          showMonetization={showMonetization}
          tools={tools}
          locale={locale}
        />
      ) : (
        <CatalogueBrowser
          client:load
          showFavorites={showFavorites}
          showMonetization={showMonetization}
          locale={locale}
        />
      )
    }
    {showInfoView && <InfoView client:idle />}
  </PageShell>
</BaseLayout>
