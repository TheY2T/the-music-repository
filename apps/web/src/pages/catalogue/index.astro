---
import CatalogueBrowser from '@/components/CatalogueBrowser.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';

const showFavorites = Astro.locals.flags.favorites && !!Astro.locals.user;
const locale = Astro.locals.locale;
---

<BaseLayout title={t(locale, 'catalogue.pageTitle')}>
  <main class="mx-auto max-w-6xl space-y-6 p-8">
    <header class="space-y-1">
      <a href={localizedPath(locale, '/')} class="text-sm text-muted-foreground underline">
        {t(locale, 'common.backHome')}
      </a>
      <h1 class="text-3xl font-bold">{t(locale, 'catalogue.title')}</h1>
      <p class="text-muted-foreground">{t(locale, 'catalogue.subtitle')}</p>
    </header>
    <CatalogueBrowser client:load showFavorites={showFavorites} locale={locale} />
  </main>
</BaseLayout>
