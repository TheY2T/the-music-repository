---
import CollectionsBrowser from '@/components/CollectionsBrowser.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';

if (!Astro.locals.flags.collections) {
  return Astro.redirect('/');
}
const locale = Astro.locals.locale;
---

<BaseLayout title={t(locale, 'collections.pageTitle')}>
  <main class="mx-auto max-w-6xl space-y-6 p-8">
    <header class="space-y-1">
      <a href={localizedPath(locale, '/')} class="text-sm text-muted-foreground underline">
        {t(locale, 'common.backHome')}
      </a>
      <h1 class="text-3xl font-bold">{t(locale, 'collections.title')}</h1>
      <p class="text-muted-foreground">{t(locale, 'collections.subtitle')}</p>
    </header>
    <CollectionsBrowser client:load locale={locale} />
  </main>
</BaseLayout>
