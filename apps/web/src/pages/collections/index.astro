---
import CollectionsBrowser from '@/components/islands/CollectionsBrowser';
import CollectionsHub from '@/components/islands/CollectionsHub';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

if (!Astro.locals.flags.collections) {
  return Astro.redirect('/');
}
const locale = Astro.locals.locale;
const { flags, user } = Astro.locals;
const showProgress = flags.progress && !!user;
const showSave = flags.collectionBookmarks && !!user;
const hub = flags.collectionsHub;
---

<BaseLayout title={t(locale, 'collections.pageTitle')}>
  <PageShell
    title={t(locale, 'collections.title')}
    subtitle={t(locale, 'collections.subtitle')}
    back={{ href: localizedPath(locale, '/'), label: t(locale, 'common.backHome') }}
    maxWidth="max-w-6xl"
  >
    {
      hub ? (
        <CollectionsHub
          client:load
          locale={locale}
          showProgress={showProgress}
          showSave={showSave}
        />
      ) : (
        <CollectionsBrowser
          client:load
          locale={locale}
          showProgress={showProgress}
          showSave={showSave}
        />
      )
    }
  </PageShell>
</BaseLayout>
