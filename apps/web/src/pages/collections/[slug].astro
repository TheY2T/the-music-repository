---
import CollectionDetail from '@/components/CollectionDetail.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

if (!Astro.locals.flags.collections) {
  return Astro.redirect('/');
}
const { slug = '' } = Astro.params;
const locale = Astro.locals.locale;
---

<BaseLayout title={t(locale, 'collections.detailPageTitle')}>
  <PageShell
    back={{ href: localizedPath(locale, '/collections'), label: t(locale, 'common.backCollections') }}
    maxWidth="max-w-3xl"
  >
    <CollectionDetail client:load slug={slug} locale={locale} />
  </PageShell>
</BaseLayout>
