---
import CircleOfFifths from '@/components/CircleOfFifths.tsx';
import InfoView from '@/components/InfoView.tsx';
import ToolPracticeLogger from '@/components/ToolPracticeLogger.tsx';
import '@/styles/global.css';

if (!Astro.locals.flags.toolCircleOfFifths) {
  return Astro.redirect('/tools');
}
const showInfoView = Astro.locals.flags.infoView;
const logPracticeEnabled =
  Astro.locals.flags.toolPractice && Astro.locals.flags.progress && !!Astro.locals.user;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Circle of fifths — The Music Repository</title>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <main class="mx-auto max-w-4xl space-y-6 p-8">
      <header class="space-y-1">
        <a href="/tools" class="text-sm text-muted-foreground underline">← Tools</a>
        <h1 class="text-3xl font-bold">Circle of fifths</h1>
      </header>
      <CircleOfFifths client:load />
    </main>
    {showInfoView && <InfoView client:idle />}
    {logPracticeEnabled && <ToolPracticeLogger client:load enabled={true} />}
  </body>
</html>
