---
import InfoView from '@TheY2T/tmr-common-ui/InfoView';
import SpeedTrainer from '@TheY2T/tmr-musickit-ui/SpeedTrainer';
import ToolPracticeLogger from '@TheY2T/tmr-common-ui/ToolPracticeLogger';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

if (!Astro.locals.flags.toolSpeedTrainer) {
  return Astro.redirect('/tools');
}
const showInfoView = Astro.locals.flags.infoView;
const logPracticeEnabled =
  Astro.locals.flags.toolPractice && Astro.locals.flags.progress && !!Astro.locals.user;
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'tool.speed-trainer.title')} — ${t(locale, 'site.name')}`}>
    <PageShell
      title={t(locale, 'tool.speed-trainer.title')}
      subtitle={t(locale, 'tool.speed-trainer.summary')}
      back={{ href: localizedPath(locale, '/tools'), label: t(locale, 'common.backTools') }}
    >
      <SpeedTrainer client:load />
    </PageShell>
    {showInfoView && <InfoView client:idle />}
    {logPracticeEnabled && <ToolPracticeLogger client:load enabled={true} />}
  </BaseLayout>
