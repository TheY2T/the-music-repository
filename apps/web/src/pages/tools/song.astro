---
import InfoView from '@/components/InfoView.tsx';
import ToolPracticeLogger from '@/components/ToolPracticeLogger.tsx';
import SongPlayer from '@/components/SongPlayer.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';

if (!Astro.locals.flags.toolSong) {
  return Astro.redirect('/tools');
}
const showInfoView = Astro.locals.flags.infoView;
const logPracticeEnabled =
  Astro.locals.flags.toolPractice && Astro.locals.flags.progress && !!Astro.locals.user;
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'tool.song.title')} — ${t(locale, 'site.name')}`}>
    <main class="mx-auto max-w-4xl space-y-6 p-8">
      <header class="space-y-1">
        <a href={localizedPath(locale, '/tools')} class="text-sm text-muted-foreground underline">{t(locale, 'common.backTools')}</a>
        <h1 class="text-3xl font-bold">{t(locale, 'tool.song.title')}</h1>
        <p class="text-muted-foreground">{t(locale, 'tool.song.summary')}</p>
      </header>
      <SongPlayer client:load />
    </main>
    {showInfoView && <InfoView client:idle />}
    {logPracticeEnabled && <ToolPracticeLogger client:load enabled={true} />}
  </BaseLayout>
