---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, type MessageKey, t } from '@TheY2T/tmr-i18n';
import { Card } from '@TheY2T/tmr-ui';
import Icon from '@TheY2T/tmr-ui/astro/Icon.astro';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

// A registered Icon-atom name per tool (falls back to `music`). Purely presentational.
const toolIcons: Record<string, string> = {
  keyboard: 'piano',
  fretboard: 'guitar',
  'circle-of-fifths': 'disc',
  'scale-explorer': 'music',
  chords: 'piano',
  'chord-identifier': 'search',
  modes: 'music',
  progression: 'list-music',
  metronome: 'clock',
  tuner: 'volume',
  intervals: 'music',
  staff: 'book-open',
  'ear-trainer': 'headphones',
  sequencer: 'sliders',
  'sight-reading': 'book-open',
  'backing-track': 'play',
  voicings: 'piano',
  player: 'play',
  licks: 'guitar',
  'chord-diagrams': 'guitar',
  strumming: 'guitar',
  fingerpicking: 'guitar',
  arpeggio: 'music',
  'progression-player': 'play',
  rhythm: 'clock',
  caged: 'guitar',
  'scale-boxes': 'guitar',
  song: 'music',
  'progression-ear': 'headphones',
  'chord-quality-ear': 'headphones',
  'fret-quiz': 'guitar',
  musicxml: 'book-open',
  'multi-voice': 'book-open',
  'practice-player': 'play',
  analyzer: 'chart',
  transposer: 'sliders',
  bassline: 'music',
  'melodic-dictation': 'headphones',
  'rhythm-dictation': 'headphones',
  grooves: 'disc',
  solfege: 'music',
  'key-quiz': 'graduation-cap',
  'interval-quiz': 'graduation-cap',
  'practice-room': 'gauge',
  score: 'book-open',
  soundfont: 'volume',
};

const {
  toolKeyboard,
  toolCircleOfFifths,
  toolFretboard,
  toolChords,
  toolScaleExplorer,
  toolChordId,
  toolModes,
  toolProgression,
  toolMetronome,
  toolTuner,
  toolIntervals,
  toolStaff,
  toolEarTrainer,
  toolSequencer,
  toolSightReading,
  toolBackingTrack,
  toolVoicings,
  toolNotationPlayer,
  toolLicks,
  toolChordDiagrams,
  toolStrumming,
  toolFingerpicking,
  toolArpeggio,
  toolProgressionPlayer,
  toolRhythm,
  toolCaged,
  toolScaleBoxes,
  toolSong,
  toolProgressionEar,
  toolChordQualityEar,
  toolFretQuiz,
  toolMusicXml,
  toolMultiVoice,
  toolPracticePlayer,
  toolAnalyzer,
  toolTransposer,
  toolBassline,
  toolMelodicDictation,
  toolRhythmDictation,
  toolGrooves,
  toolSolfege,
  toolKeyQuiz,
  toolIntervalQuiz,
  toolPracticeRoom,
  toolScore,
  toolSoundfont,
} = Astro.locals.flags;
const locale = Astro.locals.locale;

// Each tool references shared `tool.<slug>.title`/`.summary` keys (also used by its own page).
const tools: { slug: string; enabled: boolean }[] = [
  { slug: 'keyboard', enabled: toolKeyboard },
  { slug: 'fretboard', enabled: toolFretboard },
  { slug: 'circle-of-fifths', enabled: toolCircleOfFifths },
  { slug: 'scale-explorer', enabled: toolScaleExplorer },
  { slug: 'chords', enabled: toolChords },
  { slug: 'chord-identifier', enabled: toolChordId },
  { slug: 'modes', enabled: toolModes },
  { slug: 'progression', enabled: toolProgression },
  { slug: 'metronome', enabled: toolMetronome },
  { slug: 'tuner', enabled: toolTuner },
  { slug: 'intervals', enabled: toolIntervals },
  { slug: 'staff', enabled: toolStaff },
  { slug: 'ear-trainer', enabled: toolEarTrainer },
  { slug: 'sequencer', enabled: toolSequencer },
  { slug: 'sight-reading', enabled: toolSightReading },
  { slug: 'backing-track', enabled: toolBackingTrack },
  { slug: 'voicings', enabled: toolVoicings },
  { slug: 'player', enabled: toolNotationPlayer },
  { slug: 'licks', enabled: toolLicks },
  { slug: 'chord-diagrams', enabled: toolChordDiagrams },
  { slug: 'strumming', enabled: toolStrumming },
  { slug: 'fingerpicking', enabled: toolFingerpicking },
  { slug: 'arpeggio', enabled: toolArpeggio },
  { slug: 'progression-player', enabled: toolProgressionPlayer },
  { slug: 'rhythm', enabled: toolRhythm },
  { slug: 'caged', enabled: toolCaged },
  { slug: 'scale-boxes', enabled: toolScaleBoxes },
  { slug: 'song', enabled: toolSong },
  { slug: 'progression-ear', enabled: toolProgressionEar },
  { slug: 'chord-quality-ear', enabled: toolChordQualityEar },
  { slug: 'fret-quiz', enabled: toolFretQuiz },
  { slug: 'musicxml', enabled: toolMusicXml },
  { slug: 'multi-voice', enabled: toolMultiVoice },
  { slug: 'practice-player', enabled: toolPracticePlayer },
  { slug: 'analyzer', enabled: toolAnalyzer },
  { slug: 'transposer', enabled: toolTransposer },
  { slug: 'bassline', enabled: toolBassline },
  { slug: 'melodic-dictation', enabled: toolMelodicDictation },
  { slug: 'rhythm-dictation', enabled: toolRhythmDictation },
  { slug: 'grooves', enabled: toolGrooves },
  { slug: 'solfege', enabled: toolSolfege },
  { slug: 'key-quiz', enabled: toolKeyQuiz },
  { slug: 'interval-quiz', enabled: toolIntervalQuiz },
  { slug: 'practice-room', enabled: toolPracticeRoom },
  { slug: 'score', enabled: toolScore },
  { slug: 'soundfont', enabled: toolSoundfont },
].filter((tool) => tool.enabled);

if (tools.length === 0) {
  return Astro.redirect('/');
}
---

<BaseLayout title={t(locale, 'tools.pageTitle')}>
  <PageShell
    title={t(locale, 'tools.title')}
    subtitle={t(locale, 'tools.subtitle')}
    back={{ href: localizedPath(locale, '/'), label: t(locale, 'common.backHome') }}
  >
    <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        tools.map((tool) => (
          <li>
            <a href={localizedPath(locale, `/tools/${tool.slug}`)} class="group block h-full">
              <Card className="flex h-full items-start gap-3 p-4 transition group-hover:-translate-y-0.5 group-hover:border-accent group-hover:shadow-md">
                <span class="flex size-10 shrink-0 items-center justify-center rounded-md bg-accent/15 text-accent">
                  <Icon name={toolIcons[tool.slug] ?? 'music'} class="size-5" />
                </span>
                <span class="flex min-w-0 flex-col gap-1">
                  <span class="font-display font-semibold leading-tight">
                    {t(locale, `tool.${tool.slug}.title` as MessageKey)}
                  </span>
                  <span class="text-sm text-muted-foreground">
                    {t(locale, `tool.${tool.slug}.summary` as MessageKey)}
                  </span>
                </span>
              </Card>
            </a>
          </li>
        ))
      }
    </ul>
  </PageShell>
</BaseLayout>
