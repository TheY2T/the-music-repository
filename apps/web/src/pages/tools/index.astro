---
import '@/styles/global.css';

const {
  toolKeyboard,
  toolCircleOfFifths,
  toolFretboard,
  toolChords,
  toolScaleExplorer,
  toolChordId,
  toolModes,
  toolProgression,
  toolMetronome,
  toolTuner,
  toolIntervals,
  toolStaff,
  toolEarTrainer,
  toolSequencer,
  toolSightReading,
  toolBackingTrack,
  toolVoicings,
  toolNotationPlayer,
  toolLicks,
  toolChordDiagrams,
  toolStrumming,
} = Astro.locals.flags;
const tools = [
  {
    href: '/tools/keyboard',
    title: 'Interactive keyboard',
    summary: 'Click keys to hear them; highlight any scale.',
    enabled: toolKeyboard,
  },
  {
    href: '/tools/fretboard',
    title: 'Guitar fretboard',
    summary: 'Standard-tuning fretboard; hear notes and see scale shapes.',
    enabled: toolFretboard,
  },
  {
    href: '/tools/circle-of-fifths',
    title: 'Circle of fifths',
    summary: 'Explore keys, signatures, and diatonic chords.',
    enabled: toolCircleOfFifths,
  },
  {
    href: '/tools/scale-explorer',
    title: 'Scale explorer',
    summary: 'See any scale’s notes, degrees, and step pattern; play it.',
    enabled: toolScaleExplorer,
  },
  {
    href: '/tools/chords',
    title: 'Chord builder',
    summary: 'Build any chord; see its notes and hear it.',
    enabled: toolChords,
  },
  {
    href: '/tools/chord-identifier',
    title: 'Chord identifier',
    summary: 'Pick notes to name the chord (reverse lookup).',
    enabled: toolChordId,
  },
  {
    href: '/tools/modes',
    title: 'Mode explorer',
    summary: 'The seven modes, brightest to darkest, with their colour notes.',
    enabled: toolModes,
  },
  {
    href: '/tools/progression',
    title: 'Progression builder',
    summary: 'Build a chord progression and see its Roman numerals.',
    enabled: toolProgression,
  },
  {
    href: '/tools/metronome',
    title: 'Metronome',
    summary: 'Keep time with an accented, adjustable click.',
    enabled: toolMetronome,
  },
  {
    href: '/tools/tuner',
    title: 'Tuning reference',
    summary: 'Reference tones (A440 + guitar strings) to tune by ear.',
    enabled: toolTuner,
  },
  {
    href: '/tools/intervals',
    title: 'Interval explorer',
    summary: 'Hear and name any interval, melodic or harmonic.',
    enabled: toolIntervals,
  },
  {
    href: '/tools/staff',
    title: 'Staff note reader',
    summary: 'Read notes on the treble staff; click to hear them.',
    enabled: toolStaff,
  },
  {
    href: '/tools/ear-trainer',
    title: 'Ear trainer',
    summary: 'Train your ear: listen and name the interval.',
    enabled: toolEarTrainer,
  },
  {
    href: '/tools/sequencer',
    title: 'Beat sequencer',
    summary: 'Program a drum pattern and loop it.',
    enabled: toolSequencer,
  },
  {
    href: '/tools/sight-reading',
    title: 'Sight-reading',
    summary: 'Read a generated melody on the staff, then check yourself.',
    enabled: toolSightReading,
  },
  {
    href: '/tools/backing-track',
    title: 'Backing track',
    summary: 'Loop a chord progression with drums and bass to jam over.',
    enabled: toolBackingTrack,
  },
  {
    href: '/tools/voicings',
    title: 'Voicing library',
    summary: 'See a chord’s inversions, drop-2/3, and shell voicings on the keyboard.',
    enabled: toolVoicings,
  },
  {
    href: '/tools/player',
    title: 'Notation player',
    summary: 'Play a melody on the staff with a moving cursor; slow, loop, and section it.',
    enabled: toolNotationPlayer,
  },
  {
    href: '/tools/licks',
    title: 'Lick library',
    summary: 'Guitar licks and turnarounds in tab — hear them and work them up to speed.',
    enabled: toolLicks,
  },
  {
    href: '/tools/chord-diagrams',
    title: 'Chord diagrams',
    summary: 'Common open and barre guitar chord shapes — click to strum.',
    enabled: toolChordDiagrams,
  },
  {
    href: '/tools/strumming',
    title: 'Strumming trainer',
    summary: 'Loop a strum pattern over a chord and play along.',
    enabled: toolStrumming,
  },
].filter((tool) => tool.enabled);

if (tools.length === 0) {
  return Astro.redirect('/');
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tools — The Music Repository</title>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <main class="mx-auto max-w-4xl space-y-6 p-8">
      <header class="space-y-1">
        <a href="/" class="text-sm text-muted-foreground underline">← Home</a>
        <h1 class="text-3xl font-bold">Interactive tools</h1>
        <p class="text-muted-foreground">Play, explore, and hear music theory in the browser.</p>
      </header>
      <ul class="grid gap-4 sm:grid-cols-2">
        {
          tools.map((tool) => (
            <li>
              <a
                href={tool.href}
                class="flex h-full flex-col gap-1 rounded-lg border border-border p-4 transition-colors hover:bg-muted"
              >
                <span class="font-semibold">{tool.title}</span>
                <span class="text-sm text-muted-foreground">{tool.summary}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>
