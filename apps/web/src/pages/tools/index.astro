---
import ToolsBrowser, { type ToolItem } from '@/components/ToolsBrowser.tsx';
import {
  categoryOf,
  TOOL_CATEGORY_ORDER,
  TOOL_ICON,
  type ToolCategory,
} from '@/lib/tools-taxonomy';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, type MessageKey, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

const {
  toolKeyboard,
  toolCircleOfFifths,
  toolFretboard,
  toolChords,
  toolScaleExplorer,
  toolChordId,
  toolModes,
  toolProgression,
  toolMetronome,
  toolTuner,
  toolIntervals,
  toolStaff,
  toolEarTrainer,
  toolSequencer,
  toolSightReading,
  toolBackingTrack,
  toolVoicings,
  toolNotationPlayer,
  toolLicks,
  toolChordDiagrams,
  toolStrumming,
  toolFingerpicking,
  toolArpeggio,
  toolProgressionPlayer,
  toolRhythm,
  toolCaged,
  toolScaleBoxes,
  toolSong,
  toolProgressionEar,
  toolChordQualityEar,
  toolFretQuiz,
  toolMultiVoice,
  toolPracticePlayer,
  toolAnalyzer,
  toolTransposer,
  toolBassline,
  toolMelodicDictation,
  toolRhythmDictation,
  toolGrooves,
  toolSolfege,
  toolKeyQuiz,
  toolIntervalQuiz,
  toolPracticeRoom,
  toolScore,
} = Astro.locals.flags;
const locale = Astro.locals.locale;

// Each tool references shared `tool.<slug>.title`/`.summary` keys (also used by its own page).
const enabledSlugs: string[] = (
  [
    { slug: 'keyboard', enabled: toolKeyboard },
    { slug: 'fretboard', enabled: toolFretboard },
    { slug: 'circle-of-fifths', enabled: toolCircleOfFifths },
    { slug: 'scale-explorer', enabled: toolScaleExplorer },
    { slug: 'chords', enabled: toolChords },
    { slug: 'chord-identifier', enabled: toolChordId },
    { slug: 'modes', enabled: toolModes },
    { slug: 'progression', enabled: toolProgression },
    { slug: 'metronome', enabled: toolMetronome },
    { slug: 'tuner', enabled: toolTuner },
    { slug: 'intervals', enabled: toolIntervals },
    { slug: 'staff', enabled: toolStaff },
    { slug: 'ear-trainer', enabled: toolEarTrainer },
    { slug: 'sequencer', enabled: toolSequencer },
    { slug: 'sight-reading', enabled: toolSightReading },
    { slug: 'backing-track', enabled: toolBackingTrack },
    { slug: 'voicings', enabled: toolVoicings },
    { slug: 'player', enabled: toolNotationPlayer },
    { slug: 'licks', enabled: toolLicks },
    { slug: 'chord-diagrams', enabled: toolChordDiagrams },
    { slug: 'strumming', enabled: toolStrumming },
    { slug: 'fingerpicking', enabled: toolFingerpicking },
    { slug: 'arpeggio', enabled: toolArpeggio },
    { slug: 'progression-player', enabled: toolProgressionPlayer },
    { slug: 'rhythm', enabled: toolRhythm },
    { slug: 'caged', enabled: toolCaged },
    { slug: 'scale-boxes', enabled: toolScaleBoxes },
    { slug: 'song', enabled: toolSong },
    { slug: 'progression-ear', enabled: toolProgressionEar },
    { slug: 'chord-quality-ear', enabled: toolChordQualityEar },
    { slug: 'fret-quiz', enabled: toolFretQuiz },
    { slug: 'multi-voice', enabled: toolMultiVoice },
    { slug: 'practice-player', enabled: toolPracticePlayer },
    { slug: 'analyzer', enabled: toolAnalyzer },
    { slug: 'transposer', enabled: toolTransposer },
    { slug: 'bassline', enabled: toolBassline },
    { slug: 'melodic-dictation', enabled: toolMelodicDictation },
    { slug: 'rhythm-dictation', enabled: toolRhythmDictation },
    { slug: 'grooves', enabled: toolGrooves },
    { slug: 'solfege', enabled: toolSolfege },
    { slug: 'key-quiz', enabled: toolKeyQuiz },
    { slug: 'interval-quiz', enabled: toolIntervalQuiz },
    { slug: 'practice-room', enabled: toolPracticeRoom },
    { slug: 'score', enabled: toolScore },
  ] satisfies { slug: string; enabled: boolean }[]
)
  .filter((tool) => tool.enabled)
  .map((tool) => tool.slug);

if (enabledSlugs.length === 0) {
  return Astro.redirect('/');
}

// Resolve i18n strings + href + icon + category server-side; the island stays presentational.
const toolItems: ToolItem[] = enabledSlugs.map((slug) => ({
  slug,
  title: t(locale, `tool.${slug}.title` as MessageKey),
  summary: t(locale, `tool.${slug}.summary` as MessageKey),
  iconName: TOOL_ICON[slug] ?? 'music',
  href: localizedPath(locale, `/tools/${slug}`),
  category: categoryOf(slug),
}));

const CATEGORY_LABEL_KEY: Record<ToolCategory, MessageKey> = {
  'keyboard-fretboard': 'tools.category.keyboardFretboard',
  'theory-harmony': 'tools.category.theoryHarmony',
  'ear-quizzes': 'tools.category.earQuizzes',
  'rhythm-time': 'tools.category.rhythmTime',
  'reading-notation': 'tools.category.readingNotation',
  'play-practice': 'tools.category.playPractice',
};

// Only categories that actually have an enabled tool, in the canonical order.
const categories = TOOL_CATEGORY_ORDER.filter((key) =>
  toolItems.some((tool) => tool.category === key),
).map((key) => ({ key, label: t(locale, CATEGORY_LABEL_KEY[key]) }));

const strings = {
  searchPlaceholder: t(locale, 'tools.searchPlaceholder'),
  all: t(locale, 'tools.filterAll'),
  noResults: t(locale, 'tools.noResults'),
};
---

<BaseLayout title={t(locale, 'tools.pageTitle')}>
  <PageShell
    title={t(locale, 'tools.title')}
    subtitle={t(locale, 'tools.subtitle')}
    back={{ href: localizedPath(locale, '/'), label: t(locale, 'common.backHome') }}
  >
    <ToolsBrowser client:load tools={toolItems} categories={categories} strings={strings} />
  </PageShell>
</BaseLayout>
