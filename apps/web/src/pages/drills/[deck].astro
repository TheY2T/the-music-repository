---
import ReviewSession from '@/components/ReviewSession.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';

if (!Astro.locals.flags.trainers) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/drills');
}
const { deck = '' } = Astro.params;
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'drills.review')} — ${t(locale, 'site.name')}`}>
  <main class="mx-auto max-w-2xl space-y-6 p-8">
    <header class="space-y-1">
      <a href={localizedPath(locale, '/drills')} class="text-sm text-muted-foreground underline">
        {t(locale, 'common.backDrills')}
      </a>
      <h1 class="text-3xl font-bold">{t(locale, 'drills.review')}</h1>
    </header>
    <ReviewSession client:load deckKey={deck} locale={locale} />
  </main>
</BaseLayout>
