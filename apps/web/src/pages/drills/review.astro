---
import DrillSession from '@TheY2T/tmr-musickit-ui/DrillSession';
import ReviewSession from '@TheY2T/tmr-musickit-ui/ReviewSession';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

if (!Astro.locals.flags.trainers) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/drills');
}
const locale = Astro.locals.locale;
const { drillEngine, drillCelebrations } = Astro.locals.flags;
---

<BaseLayout noindex title={`${t(locale, 'drills.review')} — ${t(locale, 'site.name')}`}>
  <PageShell
    title={t(locale, 'drills.reviewAllDue')}
    back={{ href: localizedPath(locale, '/drills'), label: t(locale, 'common.backDrills') }}
    maxWidth="max-w-2xl"
  >
    {
      drillEngine ? (
        <DrillSession client:load locale={locale} celebrations={drillCelebrations} />
      ) : (
        <ReviewSession client:load locale={locale} />
      )
    }
  </PageShell>
</BaseLayout>
