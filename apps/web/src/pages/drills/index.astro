---
import DrillsHub from '@TheY2T/tmr-musickit-ui/DrillsHub';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

if (!Astro.locals.flags.trainers) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/drills');
}
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'nav.drills')} — ${t(locale, 'site.name')}`}>
  <PageShell
    title={t(locale, 'nav.drills')}
    subtitle={t(locale, 'drills.subtitle')}
    back={{ href: localizedPath(locale, '/'), label: t(locale, 'common.backHome') }}
  >
    <DrillsHub
      client:load
      locale={locale}
      flags={{
        drillPlay: Astro.locals.flags.drillPlay,
        drillEar: Astro.locals.flags.drillEar,
        drillPitch: Astro.locals.flags.drillPitch,
      }}
    />
  </PageShell>
</BaseLayout>
