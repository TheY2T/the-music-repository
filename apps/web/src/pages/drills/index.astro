---
import DrillsHub from '@/components/DrillsHub.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';

if (!Astro.locals.flags.trainers) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/drills');
}
const locale = Astro.locals.locale;
---

<BaseLayout title={`${t(locale, 'nav.drills')} — ${t(locale, 'site.name')}`}>
  <main class="mx-auto max-w-4xl space-y-6 p-8">
    <header class="space-y-1">
      <a href={localizedPath(locale, '/')} class="text-sm text-muted-foreground underline">
        {t(locale, 'common.backHome')}
      </a>
      <h1 class="text-3xl font-bold">{t(locale, 'nav.drills')}</h1>
      <p class="text-muted-foreground">{t(locale, 'drills.subtitle')}</p>
    </header>
    <DrillsHub client:load locale={locale} />
  </main>
</BaseLayout>
