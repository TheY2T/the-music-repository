---
import DrillsHub from '@/components/DrillsHub.tsx';
import '@/styles/global.css';

if (!Astro.locals.flags.trainers) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/drills');
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Drills — The Music Repository</title>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <main class="mx-auto max-w-4xl space-y-6 p-8">
      <header class="space-y-1">
        <a href="/" class="text-sm text-muted-foreground underline">← Home</a>
        <h1 class="text-3xl font-bold">Drills</h1>
        <p class="text-muted-foreground">
          Spaced-repetition practice — review a little each day to remember more.
        </p>
      </header>
      <DrillsHub client:load />
    </main>
  </body>
</html>
