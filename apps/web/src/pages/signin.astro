---
import SignInForm from '@/components/SignInForm.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';

// Already authenticated? Skip the form.
const redirectTo = Astro.url.searchParams.get('redirect') ?? '/admin';
if (Astro.locals.user) {
  return Astro.redirect(redirectTo);
}
const locale = Astro.locals.locale;
---

<BaseLayout title={t(locale, 'signin.title')}>
  <main class="mx-auto flex min-h-screen max-w-md flex-col justify-center space-y-6 p-8">
    <header class="space-y-1 text-center">
      <a href={localizedPath(locale, '/')} class="text-sm text-muted-foreground underline">
        {t(locale, 'common.backHome')}
      </a>
      <h1 class="text-3xl font-bold">{t(locale, 'signin.heading')}</h1>
      <p class="text-muted-foreground">{t(locale, 'signin.subtitle')}</p>
    </header>
    <SignInForm client:load redirectTo={redirectTo} locale={locale} />
  </main>
</BaseLayout>
