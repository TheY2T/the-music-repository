---
import SignInForm from '@TheY2T/tmr-common-ui/SignInForm';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import { buttonVariants, cn } from '@TheY2T/tmr-ui';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

// Already authenticated? Skip the form. Gated routes pass an explicit `?redirect`; a bare sign-in
// (e.g. the header link or a social sign-in) falls back to the site root, not the admin area.
const redirectTo = Astro.url.searchParams.get('redirect') ?? '/';
if (Astro.locals.user) {
  return Astro.redirect(redirectTo);
}
const locale = Astro.locals.locale;
const showSignup = Astro.locals.flags.authSignup;
const showSocial = Astro.locals.flags.authSocial;
const showMicrosoft = Astro.locals.flags.authMicrosoft;
const showMicrosoftWork = Astro.locals.flags.authMicrosoftWork;
---

<BaseLayout noindex title={t(locale, 'signin.title')}>
  <PageShell maxWidth="max-w-md" class="flex min-h-screen flex-col justify-center">
    <header class="mb-6 space-y-1 text-center">
      <a
        href={localizedPath(locale, '/')}
        class={cn(buttonVariants({ variant: 'link', size: 'sm' }), 'text-muted-foreground')}
      >
        {t(locale, 'common.backHome')}
      </a>
      <h1 class="font-display text-3xl font-semibold tracking-tight">
        {t(locale, 'signin.heading')}
      </h1>
      <p class="text-muted-foreground">{t(locale, 'signin.subtitle')}</p>
    </header>
    <SignInForm
      client:load
      redirectTo={redirectTo}
      locale={locale}
      showSignup={showSignup}
      showSocial={showSocial}
      showMicrosoft={showMicrosoft}
      showMicrosoftWork={showMicrosoftWork}
    />
  </PageShell>
</BaseLayout>
