---
import SignInForm from '@/components/SignInForm.tsx';
import '@/styles/global.css';

// Already authenticated? Skip the form.
const redirectTo = Astro.url.searchParams.get('redirect') ?? '/admin';
if (Astro.locals.user) {
  return Astro.redirect(redirectTo);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign in — The Music Repository</title>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <main class="mx-auto flex min-h-screen max-w-md flex-col justify-center space-y-6 p-8">
      <header class="space-y-1 text-center">
        <a href="/" class="text-sm text-muted-foreground underline">← Home</a>
        <h1 class="text-3xl font-bold">Sign in</h1>
        <p class="text-muted-foreground">Access the admin CMS and personalized features.</p>
      </header>
      <SignInForm client:load redirectTo={redirectTo} />
    </main>
  </body>
</html>
