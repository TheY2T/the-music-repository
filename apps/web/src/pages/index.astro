---
import HomePage from '@/components/HomePage.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';

/**
 * Homepage (Phase D) — a vintage landing built from the design-system molecules (Hero /
 * FeaturedShelf / MediaCard / CoverArt), composed in one `HomePage` island so the featured shelf
 * can fetch live catalogue data. Global header/footer come from BaseLayout. Nav/tool/premium
 * visibility follows the same flag+auth gating as the rest of the site.
 */
const { collections, premium, monetizationMessaging } = Astro.locals.flags;
const locale = Astro.locals.locale;
const user = Astro.locals.user;

// Any of the ~48 tool flags on? (mirrors src/lib/nav.ts)
const showTools = Object.entries(Astro.locals.flags).some(
  ([k, v]) => k.startsWith('tool') && k !== 'toolPractice' && v === true,
);
const showCollections = collections;
const showUpgrade = premium && monetizationMessaging && !!user;
---

<BaseLayout title={t(locale, 'home.pageTitle')}>
  <HomePage
    client:load
    locale={locale}
    catalogueHref={localizedPath(locale, '/catalogue')}
    toolsHref={localizedPath(locale, '/tools')}
    collectionsHref={localizedPath(locale, '/collections')}
    upgradeHref={localizedPath(locale, '/upgrade')}
    showTools={showTools}
    showCollections={showCollections}
    showUpgrade={showUpgrade}
    showMonetization={monetizationMessaging}
  />
</BaseLayout>
