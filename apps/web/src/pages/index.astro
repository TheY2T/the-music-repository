---
import FlagBanner from '@/components/FlagBanner.tsx';
import HealthCard from '@/components/HealthCard.tsx';
import '@/styles/global.css';

const { demoNewBanner, authEnabled, adminCms, favorites, collections, progress } = Astro.locals.flags;
const user = Astro.locals.user;
const canAuthor = adminCms && (user?.role === 'admin' || user?.role === 'editor');
const showFavorites = favorites && !!user;
const showProgress = progress && !!user;
const showDrills = Astro.locals.flags.trainers && !!user;
const showUpgrade = Astro.locals.flags.premium && !!user;
const showClassrooms = Astro.locals.flags.classrooms && !!user;
const {
  toolKeyboard,
  toolCircleOfFifths,
  toolFretboard,
  toolChords,
  toolScaleExplorer,
  toolChordId,
  toolModes,
  toolProgression,
  toolMetronome,
  toolTuner,
  toolIntervals,
  toolStaff,
  toolEarTrainer,
  toolSequencer,
  toolSightReading,
  toolBackingTrack,
  toolVoicings,
  toolNotationPlayer,
  toolLicks,
  toolChordDiagrams,
  toolStrumming,
  toolFingerpicking,
  toolArpeggio,
  toolProgressionPlayer,
  toolRhythm,
  toolCaged,
  toolScaleBoxes,
  toolSong,
  toolProgressionEar,
  toolChordQualityEar,
  toolFretQuiz,
  toolMusicXml,
  toolMultiVoice,
  toolPracticePlayer,
  toolAnalyzer,
  toolTransposer,
  toolBassline,
  toolMelodicDictation,
  toolRhythmDictation,
  toolGrooves,
  toolSolfege,
  toolKeyQuiz,
  toolIntervalQuiz,
  toolPracticeRoom,
  toolScore,
  toolSoundfont,
} = Astro.locals.flags;
const showTools =
  toolKeyboard ||
  toolCircleOfFifths ||
  toolFretboard ||
  toolChords ||
  toolScaleExplorer ||
  toolChordId ||
  toolModes ||
  toolProgression ||
  toolMetronome ||
  toolTuner ||
  toolIntervals ||
  toolStaff ||
  toolEarTrainer ||
  toolSequencer ||
  toolSightReading ||
  toolBackingTrack ||
  toolVoicings ||
  toolNotationPlayer ||
  toolLicks ||
  toolChordDiagrams ||
  toolStrumming ||
  toolFingerpicking ||
  toolArpeggio ||
  toolProgressionPlayer ||
  toolRhythm ||
  toolCaged ||
  toolScaleBoxes ||
  toolSong ||
  toolProgressionEar ||
  toolChordQualityEar ||
  toolFretQuiz ||
  toolMusicXml ||
  toolMultiVoice ||
  toolPracticePlayer ||
  toolAnalyzer ||
  toolTransposer ||
  toolBassline ||
  toolMelodicDictation ||
  toolRhythmDictation ||
  toolGrooves ||
  toolSolfege ||
  toolKeyQuiz ||
  toolIntervalQuiz ||
  toolPracticeRoom ||
  toolScore ||
  toolSoundfont;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The Music Repository</title>
    <script is:inline>
      // Apply theme before paint to avoid a flash (shadcn dark mode = `.dark` on <html>).
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <main class="mx-auto max-w-2xl space-y-6 p-8">
      <header class="space-y-1">
        <h1 class="text-3xl font-bold">The Music Repository</h1>
        <p class="text-muted-foreground">
          Phase 0 scaffold — Astro + NestJS + Postgres/Drizzle + OpenFeature.
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <a
            href="/catalogue"
            class="inline-block rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground"
          >
            Browse the catalogue →
          </a>
          {collections && <a href="/collections" class="text-sm underline">Collections</a>}
          {showTools && <a href="/tools" class="text-sm underline">Tools</a>}
          {
            authEnabled &&
              (user ? (
                <span class="text-sm text-muted-foreground">
                  {user.name || user.email}
                  {showProgress && (
                    <>
                      {' · '}
                      <a href="/me/progress" class="underline">My progress</a>
                    </>
                  )}
                  {showDrills && (
                    <>
                      {' · '}
                      <a href="/drills" class="underline">Drills</a>
                    </>
                  )}
                  {showFavorites && (
                    <>
                      {' · '}
                      <a href="/me/favorites" class="underline">My favorites</a>
                    </>
                  )}
                  {showUpgrade && (
                    <>
                      {' · '}
                      <a href="/upgrade" class="underline">Premium</a>
                    </>
                  )}
                  {showClassrooms && (
                    <>
                      {' · '}
                      <a href="/classrooms" class="underline">Classrooms</a>
                    </>
                  )}
                  {canAuthor && (
                    <>
                      {' · '}
                      <a href="/admin" class="underline">Admin</a>
                    </>
                  )}
                </span>
              ) : (
                <a href="/signin" class="text-sm underline">
                  Sign in
                </a>
              ))
          }
        </div>
      </header>

      <FlagBanner client:load initial={demoNewBanner} />
      <HealthCard client:load />
    </main>
  </body>
</html>
