---
import DashboardSpaces from '@/components/islands/DashboardSpaces';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

// The customizable practice-space builder IS the signed-in dashboard: requires the dashboard flag and
// an authenticated user. Each space carries its own animated background (folded in from the old
// standalone settings page), gated by `dashboardBackground`.
if (!Astro.locals.flags.learnerDashboard) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/dashboard');
}

const locale = Astro.locals.locale;
const backgroundEnabled = Astro.locals.flags.dashboardBackground;
---

<BaseLayout noindex title={`${t(locale, 'dashboard.title')} — ${t(locale, 'site.name')}`}>
  <PageShell
    title={t(locale, 'dashboard.title')}
    subtitle={t(locale, 'dashboard.subtitle')}
    maxWidth="max-w-6xl"
  >
    <DashboardSpaces
      client:load
      authenticated
      locale={locale}
      backgroundEnabled={backgroundEnabled}
    />
  </PageShell>
</BaseLayout>
