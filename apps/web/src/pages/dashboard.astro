---
import DashboardBackground from '@TheY2T/tmr-common-ui/DashboardBackground';
import StudioDashboard from '@TheY2T/tmr-common-ui/StudioDashboard';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@TheY2T/tmr-i18n';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

// Personalized surface: requires the flag on and an authenticated user.
if (!Astro.locals.flags.learnerDashboard) {
  return Astro.redirect('/');
}
if (!Astro.locals.user) {
  return Astro.redirect('/signin?redirect=/dashboard');
}

const locale = Astro.locals.locale;
const showFavorites = Astro.locals.flags.favorites;
const showBackground = Astro.locals.flags.dashboardBackground;
const showMonetization = Astro.locals.flags.monetizationMessaging;
---

<BaseLayout title={`${t(locale, 'dashboard.title')} — ${t(locale, 'site.name')}`}>
  <div class="relative">
    {
      showBackground && (
        <DashboardBackground
          client:only="react"
          className="pointer-events-none absolute inset-0 z-0"
        />
      )
    }
    <div class="relative z-10">
      <PageShell
        title={t(locale, 'dashboard.title')}
        subtitle={t(locale, 'dashboard.subtitle')}
        maxWidth="max-w-6xl"
      >
        <StudioDashboard
          client:load
          locale={locale}
          showFavorites={showFavorites}
          showMonetization={showMonetization}
        />
      </PageShell>
    </div>
  </div>
</BaseLayout>
