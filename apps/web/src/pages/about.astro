---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, t } from '@TheY2T/tmr-i18n';
import Icon from '@TheY2T/tmr-ui/astro/Icon.astro';
import PageShell from '@TheY2T/tmr-ui/astro/PageShell.astro';

const locale = Astro.locals.locale;
const showSupport = Astro.locals.flags.support;

const chips = [
  { icon: 'guitar', label: t(locale, 'about.chipGuitar') },
  { icon: 'piano', label: t(locale, 'about.chipPiano') },
  { icon: 'mic', label: t(locale, 'about.chipVoice') },
  { icon: 'mountain', label: t(locale, 'about.chipClimb') },
] as const;
---

<BaseLayout
  title={`${t(locale, 'nav.about')} — ${t(locale, 'site.name')}`}
  description={t(locale, 'seo.about.description')}
>
  <PageShell
    title={t(locale, 'nav.about')}
    back={{ href: localizedPath(locale, '/'), label: t(locale, 'common.backHome') }}
    maxWidth="max-w-3xl"
  >
    <div class="space-y-8">
      <div class="space-y-3">
        <p class="font-display text-2xl font-semibold text-foreground">{t(locale, 'about.greeting')}</p>
        <p class="text-base leading-relaxed text-muted-foreground">{t(locale, 'about.role')}</p>
      </div>

      <div class="space-y-5 text-sm leading-relaxed text-muted-foreground">
        <p>{t(locale, 'about.p1')}</p>
        <p>{t(locale, 'about.p2')}</p>
        <p>{t(locale, 'about.p3')}</p>
      </div>

      <section class="space-y-3">
        <h2 class="font-display text-sm font-semibold uppercase tracking-wide text-muted-foreground">
          {t(locale, 'about.chipsTitle')}
        </h2>
        <ul class="flex flex-wrap gap-2">
          {chips.map((chip) => (
            <li class="inline-flex items-center gap-2 rounded-full border border-border bg-accent/10 px-3 py-1.5 text-sm text-foreground">
              <Icon name={chip.icon} class="size-4 text-primary" />
              {chip.label}
            </li>
          ))}
        </ul>
      </section>

      {showSupport && (
        <section class="rounded-lg border border-border bg-card/40 p-5">
          <div class="flex items-start gap-3">
            <Icon name="coffee" class="mt-0.5 size-5 text-primary" />
            <div class="space-y-3">
              <p class="text-sm leading-relaxed text-muted-foreground">{t(locale, 'about.supportLead')}</p>
              <a
                href={localizedPath(locale, '/support')}
                class="inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
              >
                <Icon name="heart" class="size-4" />
                {t(locale, 'about.supportCta')}
              </a>
            </div>
          </div>
        </section>
      )}

      <p class="border-t border-border pt-6 font-display text-base text-foreground">
        {t(locale, 'about.closing')}
      </p>
    </div>
  </PageShell>
</BaseLayout>
