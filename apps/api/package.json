{
  "name": "@TheY2T/tmr-api",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node --require ./dist/otel.js dist/main.js",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check . && eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "content:build": "node scripts/build-seed-content.mjs",
    "collections:build": "node scripts/build-collections.mjs",
    "scores:build": "node scripts/build-scores.mjs",
    "scores:validate": "node scripts/validate-scores.mjs",
    "scores:migrate": "node scripts/musicxml-to-alphatex.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node dist/infrastructure/database/seed.js",
    "db:seed:auth": "node dist/infrastructure/database/seed-auth.js"
  },
  "dependencies": {
    "@TheY2T/tmr-content-serde": "workspace:*",
    "@TheY2T/tmr-contracts": "workspace:*",
    "@TheY2T/tmr-errors": "workspace:*",
    "@TheY2T/tmr-flags": "workspace:*",
    "@TheY2T/tmr-nest-platform": "workspace:*",
    "@TheY2T/tmr-observability": "workspace:*",
    "@aws-sdk/client-s3": "catalog:",
    "@aws-sdk/s3-request-presigner": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/config": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@openfeature/flagd-provider": "catalog:",
    "@openfeature/nestjs-sdk": "catalog:",
    "@openfeature/server-sdk": "catalog:",
    "@thallesp/nestjs-better-auth": "catalog:",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "meilisearch": "catalog:",
    "nestjs-pino": "catalog:",
    "nestjs-zod": "catalog:",
    "nodemailer": "^9.0.3",
    "postgres": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "stripe": "^22.3.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@TheY2T/tmr-config-eslint": "workspace:*",
    "@TheY2T/tmr-config-typescript": "workspace:*",
    "@TheY2T/tmr-config-vitest": "workspace:*",
    "@coderline/alphatab": "catalog:",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "catalog:",
    "@testcontainers/postgresql": "catalog:",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "drizzle-kit": "catalog:",
    "marked": "catalog:",
    "eslint": "catalog:",
    "supertest": "catalog:",
    "testcontainers": "catalog:",
    "typescript": "catalog:",
    "unplugin-swc": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  }
}
