{
  "extends": "../../packages/config-typescript/nestjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist",
    "types": ["node"]
  },
  // Vitest config files are executed by Vitest (type-stripped), not type-checked by tsc — including
  // them pulls the vite/rollup type graph in and conflicts. Test files under `src` are still checked.
  "include": ["src", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist"]
}
