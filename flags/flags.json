{
  "$schema": "https://flagd.dev/schema/v0/flags.json",
  "flags": {
    "auth.enabled": {
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "on"
    },
    "admin.cms": {
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "on"
    },
    "personalization.favorites": {
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "on"
    },
    "demo.new-banner": {
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off",
      "targeting": {
        "if": [
          { "in": ["beta", { "var": "roles" }] },
          "on",
          { "fractional": [["on", 10], ["off", 90]] }
        ]
      }
    }
  }
}
