# Copy to .env and adjust. Consumed by apps/api, apps/web, and infra/podman/compose.yaml.

# --- Postgres ---
POSTGRES_USER=tmr
POSTGRES_PASSWORD=tmr
POSTGRES_DB=tmr
# App connection string (host `localhost` for local dev; `db` inside podman network)
DATABASE_URL=postgres://tmr:tmr@localhost:5432/tmr

# --- API (NestJS) ---
PORT=3000
NODE_ENV=development

# --- flagd (OpenFeature provider) ---
# Start flagd + Postgres before the apps:  pnpm infra:up   (stop: pnpm infra:down)
# If flagd is unreachable the apps still run and flags fall back to their default values.
# gRPC endpoint used by the NestJS in-process/RPC provider
FLAGD_HOST=localhost
FLAGD_PORT=8013
# OFREP HTTP endpoint used by Astro SSR (server-to-server)
OFREP_BASE_URL=http://localhost:8016
# OFREP endpoint used by the browser island (public; reverse-proxied in prod)
PUBLIC_OFREP_BASE_URL=http://localhost:8016

# --- web (Astro) → api ---
API_BASE_URL=http://localhost:3000
PUBLIC_API_BASE_URL=http://localhost:3000

# --- Support (Ko-fi). The operator's Ko-fi handle powers the /support page's tip panel + link
# (public; safe to expose to the browser). ---
PUBLIC_KOFI_USERNAME=yourkofihandle

# --- Catalogue: media ---
# Base URL the browser uses to reach stored media (the API's public origin). Optional — falls back
# to BETTER_AUTH_URL, so local dev needs nothing here.
# MEDIA_PUBLIC_URL=http://localhost:3000

# --- Auth (Slice 2, Better Auth). Dev-only values; rotate for production. ---
BETTER_AUTH_SECRET=dev-insecure-secret-change-me-please-32chars
BETTER_AUTH_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:4321,http://localhost:3000

# --- Social sign-in (Google / Facebook / Microsoft). A provider is registered only when its credentials
# are set, so leaving these unset simply hides that button. Register the callback
# ${BETTER_AUTH_URL}/api/auth/callback/<provider> in each provider's developer console. ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# Personal Microsoft accounts (consumers tenant); callback .../api/auth/callback/microsoft
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# Work/school (organizational) Microsoft accounts via Entra ID; separate Azure app registration.
# Callback .../api/auth/oauth2/callback/microsoft-entra-id. MICROSOFT_WORK_TENANT_ID defaults to
# 'organizations' (any directory); set a directory GUID to scope to one organization.
# MICROSOFT_WORK_CLIENT_ID=
# MICROSOFT_WORK_CLIENT_SECRET=
# MICROSOFT_WORK_TENANT_ID=
# Sign in with Apple (auth.apple); callback .../api/auth/callback/apple (Apple POSTs back via form_post).
# APPLE_CLIENT_ID is the Services ID; the client secret is a signed ES256 JWT the API generates from the
# .p8 private key + team/key IDs and rotates automatically. Store APPLE_PRIVATE_KEY as the PEM with \n in
# place of newlines. Registers only when all four are set. See docs/runbooks/apple-oauth-setup.md.
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# --- WhatsApp phone-OTP sign-in (auth.whatsapp). Leave unset to log the code (dev/CI — no delivery).
# Set all three (token + sender phone-number id + an approved AUTHENTICATION-category template with a
# copy-code button) to send real messages via the WhatsApp Business Cloud API. TEMPLATE_LANG is the
# template's approved language code (e.g. en, en_US). ---
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_OTP_TEMPLATE_NAME=otp_code
# WHATSAPP_TEMPLATE_LANG=en
# WHATSAPP_GRAPH_VERSION=v21.0

# --- Better Auth API rate limiting. Unset ⇒ on in production, off in development/test. Set true/false to
# force it. Counters persist in Postgres (the `rate_limit` table) so limits hold across instances. ---
# AUTH_RATE_LIMIT_ENABLED=true

# --- Seed accounts (db:seed:auth). Passwords for the fixed-role accounts (admin/editor/teacher/learner
# @local.dev). Set these (per environment, e.g. Render's dev group) to real strong passwords — the seed
# creates the account with it and rotates an existing account's password to match on the next run. Unset
# ⇒ a local-dev fallback is used for new accounts and existing ones are left as-is. NEVER commit real
# values here. ---
# SEED_ADMIN_PASSWORD=
# SEED_EDITOR_PASSWORD=
# SEED_TEACHER_PASSWORD=
# SEED_LEARNER_PASSWORD=

# --- Billing (Phase 6, Stripe). Leave STRIPE_SECRET_KEY unset to use the MockCheckoutGateway
# (dev/CI — no keys, no charges). Set the price ids (test-mode) to switch to the real Stripe gateway.
# STRIPE_PRO_PRICE_ID is the Pro-tier subscription price (the checkout `plan` selects it). ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID=price_premium_...
# STRIPE_PRO_PRICE_ID=price_pro_...
STRIPE_WEBHOOK_SECRET=whsec_mock_dev_secret
WEB_BASE_URL=http://localhost:4321

# --- Mail. Leave SMTP_URL unset to use the LogMailSender (dev/CI — logs, no delivery). Set a
# connection string to switch to real SMTP. Resend: smtps://resend:<RESEND_API_KEY>@smtp.resend.com:465
# with MAIL_FROM set to a verified sender on your domain. ---
# SMTP_URL=smtps://resend:re_your_api_key@smtp.resend.com:465
MAIL_FROM=The Music Repository <no-reply@localhost>
# Where contact-form submissions are delivered.
# CONTACT_RECIPIENT=admin@themusicrepository.com

# --- Contact form anti-bot (Cloudflare Turnstile). Both unset ⇒ the challenge is skipped (local/dev).
# Set both to enforce: the secret verifies tokens server-side; the site key (PUBLIC_, baked into the web
# build) renders the widget. ---
# TURNSTILE_SECRET_KEY=
# PUBLIC_TURNSTILE_SITE_KEY=

# --- Cross-subdomain auth. Set to the shared parent domain when the web app and API run on sibling
# subdomains (e.g. web on the apex, API on api.), so the session cookie is shared. Unset for local dev. ---
# AUTH_COOKIE_DOMAIN=.themusicrepository.com

# --- Support (Ko-fi webhook). Shared token from Ko-fi's Advanced webhook settings; the inbound
# webhook rejects any payload that does not carry it. Unset ⇒ every webhook is rejected. ---
# KOFI_VERIFICATION_TOKEN=
