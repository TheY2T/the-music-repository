{
  "openapi": "3.1.0",
  "info": {
    "title": "The Music Repository API",
    "description": "The Music Repository API — the single source of truth for the HTTP contract.\nCompiles to OpenAPI 3.1 (`openapi.json`), which drives Orval (FE client + Zod) and the\nbackend Zod DTOs. Paths are declared ONLY here (never in NestJS decorators).",
    "version": "0.0.0"
  },
  "tags": [
    {
      "name": "health"
    },
    {
      "name": "demo"
    },
    {
      "name": "catalogue"
    },
    {
      "name": "authoring"
    },
    {
      "name": "favorites"
    }
  ],
  "paths": {
    "/catalogue/items": {
      "get": {
        "operationId": "searchCatalogue",
        "description": "Browse & search the catalogue with faceted filters.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "explode": false
          },
          {
            "name": "genre",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "explode": false
          },
          {
            "name": "instrument",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "explode": false
          },
          {
            "name": "topic",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "explode": false
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "lesson",
                "song",
                "score",
                "exercise",
                "technique",
                "backing_track",
                "tool_page"
              ]
            },
            "explode": false
          },
          {
            "name": "difficulty",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            },
            "explode": false
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            },
            "explode": false
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            },
            "explode": false
          }
        ],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogueList"
                }
              }
            }
          }
        },
        "tags": [
          "catalogue"
        ]
      }
    },
    "/catalogue/items/{slug}": {
      "get": {
        "operationId": "getContentBySlug",
        "description": "Fetch a single catalogue item (with taxonomy + presigned media) by slug.",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentDetail"
                }
              }
            }
          },
          "404": {
            "description": "The server cannot find the requested resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        },
        "tags": [
          "catalogue"
        ]
      }
    },
    "/content": {
      "get": {
        "operationId": "listContent",
        "description": "List every content item (all statuses) for the admin table.",
        "parameters": [],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentAdminList"
                }
              }
            }
          }
        },
        "tags": [
          "authoring"
        ]
      },
      "post": {
        "operationId": "createContent",
        "description": "Create a content item (starts as draft).",
        "parameters": [],
        "responses": {
          "201": {
            "description": "The request has succeeded and a new resource has been created as a result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentDetail"
                }
              }
            }
          }
        },
        "tags": [
          "authoring"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContentWriteInput"
              }
            }
          }
        }
      }
    },
    "/content/{slug}": {
      "get": {
        "operationId": "getContentForEdit",
        "description": "Fetch a content item of any status for editing.",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentDetail"
                }
              }
            }
          },
          "404": {
            "description": "The server cannot find the requested resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        },
        "tags": [
          "authoring"
        ]
      },
      "put": {
        "operationId": "updateContent",
        "description": "Replace a content item (taxonomy + fields).",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentDetail"
                }
              }
            }
          }
        },
        "tags": [
          "authoring"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContentWriteInput"
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteContent",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "There is no content to send for this request, but the headers may be useful. "
          }
        },
        "tags": [
          "authoring"
        ]
      }
    },
    "/content/{slug}/media": {
      "post": {
        "operationId": "requestMediaUpload",
        "description": "Reserve a media row + presigned PUT URL; the browser uploads bytes directly to storage.",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "The request has succeeded and a new resource has been created as a result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaUploadTicket"
                }
              }
            }
          }
        },
        "tags": [
          "authoring"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MediaUploadRequest"
              }
            }
          }
        }
      }
    },
    "/content/{slug}/publish": {
      "post": {
        "operationId": "publishContent",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentDetail"
                }
              }
            }
          }
        },
        "tags": [
          "authoring"
        ]
      }
    },
    "/content/{slug}/unpublish": {
      "post": {
        "operationId": "unpublishContent",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentDetail"
                }
              }
            }
          }
        },
        "tags": [
          "authoring"
        ]
      }
    },
    "/demo/error": {
      "get": {
        "operationId": "getDemoError",
        "description": "Reference endpoint that always fails with a Problem Details 404 (proves the error pipeline).",
        "parameters": [],
        "responses": {
          "404": {
            "description": "The server cannot find the requested resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        },
        "tags": [
          "demo"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatus"
                }
              }
            }
          }
        },
        "tags": [
          "health"
        ]
      }
    },
    "/me/favorites": {
      "get": {
        "operationId": "listFavorites",
        "description": "The current user's favorited content (published items).",
        "parameters": [],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FavoritesList"
                }
              }
            }
          }
        },
        "tags": [
          "favorites"
        ]
      }
    },
    "/me/favorites/{slug}": {
      "post": {
        "operationId": "addFavorite",
        "description": "Add a content item to the current user's favorites.",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "There is no content to send for this request, but the headers may be useful. "
          }
        },
        "tags": [
          "favorites"
        ]
      },
      "delete": {
        "operationId": "removeFavorite",
        "description": "Remove a content item from the current user's favorites.",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "There is no content to send for this request, but the headers may be useful. "
          }
        },
        "tags": [
          "favorites"
        ]
      }
    },
    "/taxonomy/{dimension}": {
      "get": {
        "operationId": "listTaxonomy",
        "description": "List taxonomy terms for a dimension (`genres` | `instruments` | `topics` | `tags`).",
        "parameters": [
          {
            "name": "dimension",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaxonomyList"
                }
              }
            }
          }
        },
        "tags": [
          "authoring"
        ]
      },
      "post": {
        "operationId": "createTaxonomy",
        "description": "Create (or upsert) a taxonomy term in a dimension.",
        "parameters": [
          {
            "name": "dimension",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "The request has succeeded and a new resource has been created as a result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaxonomyRef"
                }
              }
            }
          }
        },
        "tags": [
          "authoring"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaxonomyWriteInput"
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CatalogueList": {
        "type": "object",
        "required": [
          "items",
          "facets",
          "total",
          "page",
          "pageSize"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentSummary"
            }
          },
          "facets": {
            "$ref": "#/components/schemas/Facets"
          },
          "total": {
            "type": "integer",
            "format": "int32"
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "pageSize": {
            "type": "integer",
            "format": "int32"
          }
        },
        "description": "Paginated, faceted catalogue search result."
      },
      "ContentAdminList": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentAdminSummary"
            }
          }
        }
      },
      "ContentAdminSummary": {
        "type": "object",
        "required": [
          "slug",
          "title",
          "type",
          "status",
          "visibility",
          "updatedAt"
        ],
        "properties": {
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "lesson",
              "song",
              "score",
              "exercise",
              "technique",
              "backing_track",
              "tool_page"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "review",
              "published"
            ]
          },
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "authed",
              "premium"
            ]
          },
          "difficulty": {
            "type": "integer",
            "format": "int32"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "description": "Admin list row (any status)."
      },
      "ContentDetail": {
        "type": "object",
        "required": [
          "slug",
          "title",
          "type",
          "visibility",
          "genres",
          "instruments",
          "topics",
          "tags",
          "media",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "lesson",
              "song",
              "score",
              "exercise",
              "technique",
              "backing_track",
              "tool_page"
            ]
          },
          "difficulty": {
            "type": "integer",
            "format": "int32"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "authed",
              "premium"
            ]
          },
          "genres": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxonomyRef"
            }
          },
          "instruments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxonomyRef"
            }
          },
          "topics": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxonomyRef"
            }
          },
          "bodyMdx": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "attribution": {
            "type": "string"
          },
          "license": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxonomyRef"
            }
          },
          "media": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MediaAsset"
            }
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "description": "Full detail view of a catalogue item."
      },
      "ContentSummary": {
        "type": "object",
        "required": [
          "slug",
          "title",
          "type",
          "visibility",
          "genres",
          "instruments",
          "topics"
        ],
        "properties": {
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "lesson",
              "song",
              "score",
              "exercise",
              "technique",
              "backing_track",
              "tool_page"
            ]
          },
          "difficulty": {
            "type": "integer",
            "format": "int32"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "authed",
              "premium"
            ]
          },
          "genres": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxonomyRef"
            }
          },
          "instruments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxonomyRef"
            }
          },
          "topics": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxonomyRef"
            }
          }
        },
        "description": "List/card view of a catalogue item."
      },
      "ContentWriteInput": {
        "type": "object",
        "required": [
          "slug",
          "title",
          "type",
          "genres",
          "instruments",
          "topics",
          "tags"
        ],
        "properties": {
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "bodyMdx": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "lesson",
              "song",
              "score",
              "exercise",
              "technique",
              "backing_track",
              "tool_page"
            ]
          },
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "authed",
              "premium"
            ]
          },
          "difficulty": {
            "type": "integer",
            "format": "int32"
          },
          "source": {
            "type": "string"
          },
          "attribution": {
            "type": "string"
          },
          "license": {
            "type": "string"
          },
          "genres": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "instruments": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "topics": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "description": "Create/replace payload for a content item. Taxonomy is given as slug arrays."
      },
      "FacetValue": {
        "type": "object",
        "required": [
          "value",
          "label",
          "count"
        ],
        "properties": {
          "value": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "format": "int32"
          }
        },
        "description": "One facet bucket (a value + its result count)."
      },
      "Facets": {
        "type": "object",
        "required": [
          "genres",
          "instruments",
          "topics",
          "types",
          "difficulties"
        ],
        "properties": {
          "genres": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FacetValue"
            }
          },
          "instruments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FacetValue"
            }
          },
          "topics": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FacetValue"
            }
          },
          "types": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FacetValue"
            }
          },
          "difficulties": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FacetValue"
            }
          }
        },
        "description": "Available facets for the current result set."
      },
      "FavoritesList": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentSummary"
            }
          }
        }
      },
      "HealthChecks": {
        "type": "object",
        "required": [
          "database"
        ],
        "properties": {
          "database": {
            "type": "string",
            "enum": [
              "up",
              "down"
            ]
          }
        }
      },
      "HealthStatus": {
        "type": "object",
        "required": [
          "status",
          "service",
          "version",
          "uptimeSeconds",
          "checks"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "degraded",
              "down"
            ]
          },
          "service": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "uptimeSeconds": {
            "type": "integer",
            "format": "int32"
          },
          "checks": {
            "$ref": "#/components/schemas/HealthChecks"
          }
        },
        "description": "Service health snapshot."
      },
      "MediaAsset": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "url",
          "filename",
          "mime"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
