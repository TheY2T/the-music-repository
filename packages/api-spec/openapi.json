{
  "openapi": "3.1.0",
  "info": {
    "title": "The Music Repository API",
    "description": "The Music Repository API — the single source of truth for the HTTP contract.\nCompiles to OpenAPI 3.1 (`openapi.json`), which drives Orval (FE client + Zod) and the\nbackend Zod DTOs. Paths are declared ONLY here (never in NestJS decorators).",
    "version": "0.0.0"
  },
  "tags": [
    {
      "name": "health"
    },
    {
      "name": "demo"
    },
    {
      "name": "catalogue"
    }
  ],
  "paths": {
    "/catalogue/items": {
      "get": {
        "operationId": "searchCatalogue",
        "description": "Browse & search the catalogue with faceted filters.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "explode": false
          },
          {
            "name": "genre",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "explode": false
          },
          {
            "name": "instrument",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "explode": false
          },
          {
            "name": "topic",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "explode": false
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "lesson",
                "song",
                "score",
                "exercise",
                "technique",
                "backing_track",
                "tool_page"
              ]
            },
            "explode": false
          },
          {
            "name": "difficulty",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            },
            "explode": false
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            },
            "explode": false
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            },
            "explode": false
          }
        ],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogueList"
                }
              }
            }
          }
        },
        "tags": [
          "catalogue"
        ]
      }
    },
    "/catalogue/items/{slug}": {
      "get": {
        "operationId": "getContentBySlug",
        "description": "Fetch a single catalogue item (with taxonomy + presigned media) by slug.",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentDetail"
                }
              }
            }
          },
          "404": {
            "description": "The server cannot find the requested resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        },
        "tags": [
          "catalogue"
        ]
      }
    },
    "/demo/error": {
      "get": {
        "operationId": "getDemoError",
        "description": "Reference endpoint that always fails with a Problem Details 404 (proves the error pipeline).",
        "parameters": [],
        "responses": {
          "404": {
            "description": "The server cannot find the requested resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        },
        "tags": [
          "demo"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatus"
                }
              }
            }
          }
        },
        "tags": [
          "health"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "CatalogueList": {
        "type": "object",
        "required": [
          "items",
          "facets",
          "total",
          "page",
          "pageSize"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentSummary"
            }
          },
          "facets": {
            "$ref": "#/components/schemas/Facets"
          },
          "total": {
            "type": "integer",
            "format": "int32"
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "pageSize": {
            "type": "integer",
            "format": "int32"
          }
        },
        "description": "Paginated, faceted catalogue search result."
      },
      "ContentDetail": {
        "type": "object",
        "required": [
          "slug",
          "title",
          "type",
          "visibility",
          "genres",
          "instruments",
          "topics",
          "tags",
          "media",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "lesson",
              "song",
              "score",
              "exercise",
              "technique",
              "backing_track",
              "tool_page"
            ]
          },
          "difficulty": {
            "type": "integer",
            "format": "int32"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "authed",
              "premium"
            ]
          },
          "genres": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxonomyRef"
            }
          },
          "instruments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxonomyRef"
            }
          },
          "topics": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxonomyRef"
            }
          },
          "bodyMdx": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "attribution": {
            "type": "string"
          },
          "license": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxonomyRef"
            }
          },
          "media": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MediaAsset"
            }
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "description": "Full detail view of a catalogue item."
      },
      "ContentSummary": {
        "type": "object",
        "required": [
          "slug",
          "title",
          "type",
          "visibility",
          "genres",
          "instruments",
          "topics"
        ],
        "properties": {
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "lesson",
              "song",
              "score",
              "exercise",
              "technique",
              "backing_track",
              "tool_page"
            ]
          },
          "difficulty": {
            "type": "integer",
            "format": "int32"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "authed",
              "premium"
            ]
          },
          "genres": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxonomyRef"
            }
          },
          "instruments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxonomyRef"
            }
          },
          "topics": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxonomyRef"
            }
          }
        },
        "description": "List/card view of a catalogue item."
      },
      "FacetValue": {
        "type": "object",
        "required": [
          "value",
          "label",
          "count"
        ],
        "properties": {
          "value": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "format": "int32"
          }
        },
        "description": "One facet bucket (a value + its result count)."
      },
      "Facets": {
        "type": "object",
        "required": [
          "genres",
          "instruments",
          "topics",
          "types",
          "difficulties"
        ],
        "properties": {
          "genres": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FacetValue"
            }
          },
          "instruments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FacetValue"
            }
          },
          "topics": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FacetValue"
            }
          },
          "types": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FacetValue"
            }
          },
          "difficulties": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FacetValue"
            }
          }
        },
        "description": "Available facets for the current result set."
      },
      "HealthChecks": {
        "type": "object",
        "required": [
          "database"
        ],
        "properties": {
          "database": {
            "type": "string",
            "enum": [
              "up",
              "down"
            ]
          }
        }
      },
      "HealthStatus": {
        "type": "object",
        "required": [
          "status",
          "service",
          "version",
          "uptimeSeconds",
          "checks"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "degraded",
              "down"
            ]
          },
          "service": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "uptimeSeconds": {
            "type": "integer",
            "format": "int32"
          },
          "checks": {
            "$ref": "#/components/schemas/HealthChecks"
          }
        },
        "description": "Service health snapshot."
      },
      "MediaAsset": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "url",
          "filename",
          "mime"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "score_pdf",
              "audio",
              "image",
              "midi",
              "musicxml"
            ]
          },
          "url": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "mime": {
            "type": "string"
          },
          "license": {
            "type": "string"
          },
          "attribution": {
            "type": "string"
          }
        },
        "description": "A media file attached to a content item, with a ready-to-use (presigned) URL."
      },
      "ProblemDetails": {
        "type": "object",
        "required": [
          "type",
          "title",
          "status",
          "code"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "URI identifying the problem category."
          },
          "title": {
            "type": "string",
            "description": "Short, stable, human summary of the problem type."
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "description": "HTTP status code."
          },
          "detail": {
            "type": "string",
            "description": "Human explanation of this occurrence."
          },
          "instance": {
            "type": "string",
            "description": "URI identifying this specific occurrence."
          },
          "code": {
            "type": "string",
            "description": "Stable machine-readable code — the programmatic contract."
          },
          "traceId": {
            "type": "string",
            "description": "W3C trace id for support correlation."
          },
          "docUrl": {
            "type": "string",
            "description": "Link to human documentation for this code."
          }
        },
        "description": "RFC 9457 Problem Details (`application/problem+json`)."
      },
      "TaxonomyRef": {
        "type": "object",
        "required": [
          "slug",
          "name"
        ],
        "properties": {
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "description": "A taxonomy reference (genre / instrument / topic / tag)."
      }
    }
  }
}
